\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces The substrate--accelerant architecture. The LLM synthesis layer sits \emph  {inside} a larger recursion loop: models generate repositories that feed future training. The substrate layer preceded the synthesis layer by over a decade.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:substrate}{{1}{4}{The substrate--accelerant architecture. The LLM synthesis layer sits \emph {inside} a larger recursion loop: models generate repositories that feed future training. The substrate layer preceded the synthesis layer by over a decade}{figure.1}{}}
\newlabel{fig:substrate@cref}{{[figure][1][]1}{[1][4][]4}}
\@writefile{toc}{\contentsline {section}{\numberline {1}Introduction: Locating the Explosion}{4}{section.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces The three tiers of admissibility. Tier~1 (inner, white): stable $\Phi >0$, robust contribution. Tier~2 (middle gray annulus): near $Z(\Phi )$, recoverable via forking. Tier~3 (outer, darker): no replay structure, outside the admissibility manifold.}}{5}{figure.2}\protected@file@percent }
\newlabel{fig:admissibility}{{2}{5}{The three tiers of admissibility. Tier~1 (inner, white): stable $\Phi >0$, robust contribution. Tier~2 (middle gray annulus): near $Z(\Phi )$, recoverable via forking. Tier~3 (outer, darker): no replay structure, outside the admissibility manifold}{figure.2}{}}
\newlabel{fig:admissibility@cref}{{[figure][2][]2}{[1][4][]5}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Repository replay as braided attractor trajectories. Forks, repairs, and reinterpretations converge on the attractor basin despite local divergence. Near-boundary trajectories may stall. The basin is defined by convergence of the replay distribution $\sigma _n \sim \mathbb  {P}_n$.}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:replay}{{3}{5}{Repository replay as braided attractor trajectories. Forks, repairs, and reinterpretations converge on the attractor basin despite local divergence. Near-boundary trajectories may stall. The basin is defined by convergence of the replay distribution $\sigma _n \sim \mathbb {P}_n$}{figure.3}{}}
\newlabel{fig:replay@cref}{{[figure][3][]3}{[1][4][]5}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces The lamphron--lamphrodyne dual cycle. Lamphron (compact, specialized) repositories create conditions for lamphrodyne integration (composite systems). Integration generates new problems that spawn new specialized repositories, closing the recursive loop.}}{6}{figure.4}\protected@file@percent }
\newlabel{fig:lamphron}{{4}{6}{The lamphron--lamphrodyne dual cycle. Lamphron (compact, specialized) repositories create conditions for lamphrodyne integration (composite systems). Integration generates new problems that spawn new specialized repositories, closing the recursive loop}{figure.4}{}}
\newlabel{fig:lamphron@cref}{{[figure][4][]4}{[1][4][]6}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces The semantic quantization sequence. \texttt  {AmbiBFMachine}: raw stochastic tape. \texttt  {Spherepop}: parity-preserving metastable bubbles. Quantum SpherePop: coupled phase lattice $\Psi _i = r_i e^{i\theta _i}$. Each stage preserves invariant developmental geometry while increasing representational richness.}}{6}{figure.5}\protected@file@percent }
\newlabel{fig:quantization}{{5}{6}{The semantic quantization sequence. \texttt {AmbiBFMachine}: raw stochastic tape. \texttt {Spherepop}: parity-preserving metastable bubbles. Quantum SpherePop: coupled phase lattice $\Psi _i = r_i e^{i\theta _i}$. Each stage preserves invariant developmental geometry while increasing representational richness}{figure.5}{}}
\newlabel{fig:quantization@cref}{{[figure][5][]5}{[1][4][]6}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Structural homology between the biological cortex and the GitHub ecosystem. Both implement distributed working memory through analogous functional layers. The homology is functional and architectural.}}{7}{figure.6}\protected@file@percent }
\newlabel{fig:cortex}{{6}{7}{Structural homology between the biological cortex and the GitHub ecosystem. Both implement distributed working memory through analogous functional layers. The homology is functional and architectural}{figure.6}{}}
\newlabel{fig:cortex@cref}{{[figure][6][]6}{[1][4][]7}}
