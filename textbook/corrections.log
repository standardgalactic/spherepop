 412, 1080, 8236, 12437, 1496, 307, 1400, 18834, 293, 11939, 11, 1400, 544, 9113, 813, 264, 22195, 2487, 321, 764, 281, 1461, 309, 13, 50790], "temperature": 0.0, "avg_logprob": -0.10731040983271778, "compression_ratio": 1.6070381231671553, "no_speech_prob": 6.259822846708951e-13}, {"id": 7, "seek": 2650, "start": 35.18, "end": 40.86, "text": " Because we've spent decades, literally decades, forcing machines to think in absolute binaries.", "tokens": [50799, 1436, 321, 600, 4418, 7878, 11, 3736, 7878, 11, 19030, 8379, 281, 519, 294, 8236, 5171, 4889, 13, 51083], "temperature": 0.0, "avg_logprob": -0.10731040983271778, "compression_ratio": 1.6070381231671553, "no_speech_prob": 6.259822846708951e-13}, {"id": 8, "seek": 2650, "start": 41.1, "end": 43.24, "text": " And if you've ever tried coding, you know that pain.", "tokens": [51095, 400, 498, 291, 600, 1562, 3031, 17720, 11, 291, 458, 300, 1822, 13, 51202], "temperature": 0.0, "avg_logprob": -0.10731040983271778, "compression_ratio": 1.6070381231671553, "no_speech_prob": 6.259822846708951e-13}, {"id": 9, "seek": 2650, "start": 43.42, "end": 49.54, "text": " I mean, I spent three days last month just trying to debug this simple Python script that was supposed to automate my email.", "tokens": [51211, 286, 914, 11, 286, 4418, 1045, 1708, 1036, 1618, 445, 1382, 281, 24083, 341, 2199, 15329, 5755, 300, 390, 3442, 281, 31605, 452, 3796, 13, 51517], "temperature": 0.0, "avg_logprob": -0.10731040983271778, "compression_ratio": 1.6070381231671553, "no_speech_prob": 6.259822846708951e-13}, {"id": 10, "seek": 2650, "start": 49.760000000000005, "end": 50.32, "text": " Oh, yeah.", "tokens": [51528, 876, 11, 1338, 13, 51556], "temperature": 0.0, "avg_logprob": -0.10731040983271778, "compression_ratio": 1.6070381231671553, "no_speech_prob": 6.259822846708951e-13}, {"id": 11, "seek": 2650, "start": 50.519999999999996, "end": 51.379999999999995, "text": " That's always fun.", "tokens": [51566, 663, 311, 1009, 1019, 13, 51609], "temperature": 0.0, "avg_logprob": -0.10731040983271778, "compression_ratio": 1.6070381231671553, "no_speech_prob": 6.259822846708951e-13}, {"id": 12, "seek": 2650, "start": 51.44, "end": 51.6, "text": " Right.", "tokens": [51612, 1779, 13, 51620], "temperature": 0.0, "avg_logprob": -0.10731040983271778, "compression_ratio": 1.6070381231671553, "no_speech_prob": 6.259822846708951e-13}, {"id": 13, "seek": 2650, "start": 51.68, "end": 54.68, "text": " And the entire thing crashed because of a single missing parenthesis.", "tokens": [51624, 400, 264, 2302, 551, 24190, 570, 295, 257, 2167, 5361, 23350, 9374, 13, 51774], "temperature": 0.0, "avg_logprob": -0.10731040983271778, "compression_ratio": 1.6070381231671553, "no_speech_prob": 6.259822846708951e-13}, {"id": 14, "seek": 2650, "start": 55.019999999999996, "end": 55.5, "text": " Exactly.", "tokens": [51791, 7587, 13, 51815], "temperature": 0.0, "avg_logprob": -0.10731040983271778, "compression_ratio": 1.6070381231671553, "no_speech_prob": 6.259822846708951e-13}, {"id": 15, "seek": 5550, "start": 55.5, "end": 59.6, "text": " You build this rigid architecture, just laying bricks of code line by line.", "tokens": [50365, 509, 1322, 341, 22195, 9482, 11, 445, 14903, 25497, 295, 3089, 1622, 538, 1622, 13, 50570], "temperature": 0.0, "avg_logprob": -0.11295567136822325, "compression_ratio": 1.6386292834890965, "no_speech_prob": 1.2494685191002941e-12}, {"id": 16, "seek": 5550, "start": 59.8, "end": 64.52, "text": " And if one brick is a millimeter out of place, the compiler just throws a fatal error.", "tokens": [50580, 400, 498, 472, 16725, 307, 257, 17942, 484, 295, 1081, 11, 264, 31958, 445, 19251, 257, 24069, 6713, 13, 50816], "temperature": 0.0, "avg_logprob": -0.11295567136822325, "compression_ratio": 1.6386292834890965, "no_speech_prob": 1.2494685191002941e-12}, {"id": 17, "seek": 5550, "start": 64.82, "end": 66.4, "text": " Which is incredibly fragile.", "tokens": [50831, 3013, 307, 6252, 23847, 13, 50910], "temperature": 0.0, "avg_logprob": -0.11295567136822325, "compression_ratio": 1.6386292834890965, "no_speech_prob": 1.2494685191002941e-12}, {"id": 18, "seek": 5550, "start": 66.62, "end": 71.98, "text": " I mean, we've built our entire digital civilization on that text-based, top-down fragility.", "tokens": [50921, 286, 914, 11, 321, 600, 3094, 527, 2302, 4562, 18036, 322, 300, 2487, 12, 6032, 11, 1192, 12, 5093, 9241, 1140, 13, 51189], "temperature": 0.0, "avg_logprob": -0.11295567136822325, "compression_ratio": 1.6386292834890965, "no_speech_prob": 1.2494685191002941e-12}, {"id": 19, "seek": 5550, "start": 72.18, "end": 73.74000000000001, "text": " Well, welcome to this deep dive.", "tokens": [51199, 1042, 11, 2928, 281, 341, 2452, 9192, 13, 51277], "temperature": 0.0, "avg_logprob": -0.11295567136822325, "compression_ratio": 1.6386292834890965, "no_speech_prob": 1.2494685191002941e-12}, {"id": 20, "seek": 5550, "start": 74.24000000000001, "end": 80.48, "text": " If you're joining us today, and, you know, as the learner, I know you're here because you love connecting the dots across complex systems.", "tokens": [51302, 759, 291, 434, 5549, 505, 965, 11, 293, 11, 291, 458, 11, 382, 264, 33347, 11, 286, 458, 291, 434, 510, 570, 291, 959, 11015, 264, 15026, 2108, 3997, 3652, 13, 51614], "temperature": 0.0, "avg_logprob": -0.11295567136822325, "compression_ratio": 1.6386292834890965, "no_speech_prob": 1.2494685191002941e-12}, {"id": 21, "seek": 5550, "start": 81.03999999999999, "end": 83.9, "text": " We are embarking on something incredibly special today.", "tokens": [51642, 492, 366, 29832, 278, 322, 746, 6252, 2121, 965, 13, 51785], "temperature": 0.0, "avg_logprob": -0.11295567136822325, "compression_ratio": 1.6386292834890965, "no_speech_prob": 1.2494685191002941e-12}, {"id": 22, "seek": 5550, "start": 84.0, "end": 84.66, "text": " We really are.", "tokens": [51790, 492, 534, 366, 13, 51823], "temperature": 0.0, "avg_logprob": -0.11295567136822325, "compression_ratio": 1.6386292834890965, "no_speech_prob": 1.2494685191002941e-12}, {"id": 23, "seek": 8466, "start": 84.66, "end": 93.89999999999999, "text": " We're looking at a trio of visionary, incredibly dense academic papers published between 2025 and 2026 by the Flixian Research Group.", "tokens": [50365, 492, 434, 1237, 412, 257, 37274, 295, 49442, 11, 6252, 18011, 7778, 10577, 6572, 1296, 39209, 293, 945, 10880, 538, 264, 3235, 970, 952, 10303, 10500, 13, 50827], "temperature": 0.0, "avg_logprob": -0.11194614441164079, "compression_ratio": 1.1565217391304348, "no_speech_prob": 1.2394767287191022e-12}, {"id": 24, "seek": 9390, "start": 93.9, "end": 100.42, "text": " So we're talking about sphere pop calculus, the geometry of sphere pop, and types as refusal structures.", "tokens": [50365, 407, 321, 434, 1417, 466, 16687, 1665, 33400, 11, 264, 18426, 295, 16687, 1665, 11, 293, 3467, 382, 48948, 9227, 13, 50691], "temperature": 0.0, "avg_logprob": -0.13723869783332548, "compression_ratio": 1.5769230769230769, "no_speech_prob": 1.5491509984533192e-12}, {"id": 25, "seek": 9390, "start": 100.86, "end": 100.9, "text": " Right.", "tokens": [50713, 1779, 13, 50715], "temperature": 0.0, "avg_logprob": -0.13723869783332548, "compression_ratio": 1.5769230769230769, "no_speech_prob": 1.5491509984533192e-12}, {"id": 26, "seek": 9390, "start": 101.12, "end": 104.82000000000001, "text": " And our mission today is to extract the ultimate insights from these sources.", "tokens": [50726, 400, 527, 4447, 965, 307, 281, 8947, 264, 9705, 14310, 490, 613, 7139, 13, 50911], "temperature": 0.0, "avg_logprob": -0.13723869783332548, "compression_ratio": 1.5769230769230769, "no_speech_prob": 1.5491509984533192e-12}, {"id": 27, "seek": 9390, "start": 105.22, "end": 115.16000000000001, "text": " And honestly, they propose a total reimagining of how we write code, how we approach artificial general intelligence safety, and like we just said, how we understand logic itself.", "tokens": [50931, 400, 6095, 11, 436, 17421, 257, 3217, 319, 25228, 1760, 295, 577, 321, 2464, 3089, 11, 577, 321, 3109, 11677, 2674, 7599, 4514, 11, 293, 411, 321, 445, 848, 11, 577, 321, 1223, 9952, 2564, 13, 51428], "temperature": 0.0, "avg_logprob": -0.13723869783332548, "compression_ratio": 1.5769230769230769, "no_speech_prob": 1.5491509984533192e-12}, {"id": 28, "seek": 11516, "start": 115.16, "end": 121.24, "text": " But before we begin unpacking all of this, there is a really crucial caveat regarding the source material that we need to mention.", "tokens": [50365, 583, 949, 321, 1841, 26699, 278, 439, 295, 341, 11, 456, 307, 257, 534, 11462, 43012, 8595, 264, 4009, 2527, 300, 321, 643, 281, 2152, 13, 50669], "temperature": 0.0, "avg_logprob": -0.11236556883781187, "compression_ratio": 1.5444015444015444, "no_speech_prob": 1.6106117091060912e-12}, {"id": 29, "seek": 11516, "start": 121.64, "end": 122.56, "text": " Yeah, that's a good point.", "tokens": [50689, 865, 11, 300, 311, 257, 665, 935, 13, 50735], "temperature": 0.0, "avg_logprob": -0.11236556883781187, "compression_ratio": 1.5444015444015444, "no_speech_prob": 1.6106117091060912e-12}, {"id": 30, "seek": 11516, "start": 122.89999999999999, "end": 127.34, "text": " The Flixian authors take a very specific, highly debated stance on AGI safety.", "tokens": [50752, 440, 3235, 970, 952, 16552, 747, 257, 588, 2685, 11, 5405, 42212, 21033, 322, 316, 26252, 4514, 13, 50974], "temperature": 0.0, "avg_logprob": -0.11236556883781187, "compression_ratio": 1.5444015444015444, "no_speech_prob": 1.6106117091060912e-12}, {"id": 31, "seek": 11516, "start": 127.72, "end": 137.0, "text": " They argue quite forcefully against centralized control, against containment, and against these precautionary doom narratives that are so popular right now.", "tokens": [50993, 814, 9695, 1596, 3464, 2277, 1970, 32395, 1969, 11, 1970, 44058, 11, 293, 1970, 613, 25651, 1448, 822, 37131, 28016, 300, 366, 370, 3743, 558, 586, 13, 51457], "temperature": 0.0, "avg_logprob": -0.11236556883781187, "compression_ratio": 1.5444015444015444, "no_speech_prob": 1.6106117091060912e-12}, {"id": 32, "seek": 11516, "start": 137.07999999999998, "end": 137.28, "text": " Right.", "tokens": [51461, 1779, 13, 51471], "temperature": 0.0, "avg_logprob": -0.11236556883781187, "compression_ratio": 1.5444015444015444, "no_speech_prob": 1.6106117091060912e-12}, {"id": 33, "seek": 13728, "start": 137.28, "end": 141.16, "text": " The whole AI is going to destroy us, so we must lock it in a box idea.", "tokens": [50365, 440, 1379, 7318, 307, 516, 281, 5293, 505, 11, 370, 321, 1633, 4017, 309, 294, 257, 2424, 1558, 13, 50559], "temperature": 0.0, "avg_logprob": -0.18036605316458396, "compression_ratio": 1.5488721804511278, "no_speech_prob": 1.507369424592897e-12}, {"id": 34, "seek": 13728, "start": 141.3, "end": 141.82, "text": " Exactly.", "tokens": [50566, 7587, 13, 50592], "temperature": 0.0, "avg_logprob": -0.18036605316458396, "compression_ratio": 1.5488721804511278, "no_speech_prob": 1.507369424592897e-12}, {"id": 35, "seek": 13728, "start": 142.34, "end": 145.06, "text": " So our goal today is strictly analytical.", "tokens": [50618, 407, 527, 3387, 965, 307, 20792, 29579, 13, 50754], "temperature": 0.0, "avg_logprob": -0.18036605316458396, "compression_ratio": 1.5488721804511278, "no_speech_prob": 1.507369424592897e-12}, {"id": 36, "seek": 13728, "start": 145.66, "end": 148.8, "text": " We are impartial guides exploring this fascinating framework.", "tokens": [50784, 492, 366, 32177, 831, 17007, 12736, 341, 10343, 8388, 13, 50941], "temperature": 0.0, "avg_logprob": -0.18036605316458396, "compression_ratio": 1.5488721804511278, "no_speech_prob": 1.507369424592897e-12}, {"id": 37, "seek": 13728, "start": 149.2, "end": 152.72, "text": " We are endorsing one side of the AGI safety debate over another.", "tokens": [50961, 492, 366, 37676, 278, 472, 1252, 295, 264, 316, 26252, 4514, 7958, 670, 1071, 13, 51137], "temperature": 0.0, "avg_logprob": -0.18036605316458396, "compression_ratio": 1.5488721804511278, "no_speech_prob": 1.507369424592897e-12}, {"id": 38, "seek": 13728, "start": 152.88, "end": 153.8, "text": " We're just looking at the math.", "tokens": [51145, 492, 434, 445, 1237, 412, 264, 5221, 13, 51191], "temperature": 0.0, "avg_logprob": -0.18036605316458396, "compression_ratio": 1.5488721804511278, "no_speech_prob": 1.507369424592897e-12}, {"id": 39, "seek": 13728, "start": 153.96, "end": 154.2, "text": " Right.", "tokens": [51199, 1779, 13, 51211], "temperature": 0.0, "avg_logprob": -0.18036605316458396, "compression_ratio": 1.5488721804511278, "no_speech_prob": 1.507369424592897e-12}, {"id": 40, "seek": 13728, "start": 154.48, "end": 160.2, "text": " Our objective is simply to help you understand the profound mechanics and the philosophy that are presented in these papers.", "tokens": [51225, 2621, 10024, 307, 2935, 281, 854, 291, 1223, 264, 14382, 12939, 293, 264, 10675, 300, 366, 8212, 294, 613, 10577, 13, 51511], "temperature": 0.0, "avg_logprob": -0.18036605316458396, "compression_ratio": 1.5488721804511278, "no_speech_prob": 1.507369424592897e-12}, {"id": 41, "seek": 16020, "start": 160.2, "end": 164.61999999999998, "text": " And we are here to cut through the heavy jargon, because there's a lot of it.", "tokens": [50365, 400, 321, 366, 510, 281, 1723, 807, 264, 4676, 15181, 10660, 11, 570, 456, 311, 257, 688, 295, 309, 13, 50586], "temperature": 0.0, "avg_logprob": -0.11478842367040049, "compression_ratio": 1.6033755274261603, "no_speech_prob": 1.4956336950172622e-12}, {"id": 42, "seek": 16020, "start": 164.95999999999998, "end": 170.35999999999999, "text": " So to understand these grand theories of AI and the universe, we really have to start at the bedrock.", "tokens": [50603, 407, 281, 1223, 613, 2697, 13667, 295, 7318, 293, 264, 6445, 11, 321, 534, 362, 281, 722, 412, 264, 2901, 17799, 13, 50873], "temperature": 0.0, "avg_logprob": -0.11478842367040049, "compression_ratio": 1.6033755274261603, "no_speech_prob": 1.4956336950172622e-12}, {"id": 43, "seek": 16020, "start": 170.57999999999998, "end": 170.82, "text": " We do.", "tokens": [50884, 492, 360, 13, 50896], "temperature": 0.0, "avg_logprob": -0.11478842367040049, "compression_ratio": 1.6033755274261603, "no_speech_prob": 1.4956336950172622e-12}, {"id": 44, "seek": 16020, "start": 170.98, "end": 177.35999999999999, "text": " We have to look at how this framework rethinks the most basic building block of our digital world, which is computer programming.", "tokens": [50904, 492, 362, 281, 574, 412, 577, 341, 8388, 319, 392, 16431, 264, 881, 3875, 2390, 3461, 295, 527, 4562, 1002, 11, 597, 307, 3820, 9410, 13, 51223], "temperature": 0.0, "avg_logprob": -0.11478842367040049, "compression_ratio": 1.6033755274261603, "no_speech_prob": 1.4956336950172622e-12}, {"id": 45, "seek": 16020, "start": 177.79999999999998, "end": 181.7, "text": " And to do that, we need to talk about blowing bubbles.", "tokens": [51245, 400, 281, 360, 300, 11, 321, 643, 281, 751, 466, 15068, 16295, 13, 51440], "temperature": 0.0, "avg_logprob": -0.11478842367040049, "compression_ratio": 1.6033755274261603, "no_speech_prob": 1.4956336950172622e-12}, {"id": 46, "seek": 16020, "start": 182.07999999999998, "end": 182.39999999999998, "text": " Bubbles.", "tokens": [51459, 25489, 8806, 13, 51475], "temperature": 0.0, "avg_logprob": -0.11478842367040049, "compression_ratio": 1.6033755274261603, "no_speech_prob": 1.4956336950172622e-12}, {"id": 47, "seek": 18240, "start": 182.4, "end": 182.76000000000002, "text": " Yeah.", "tokens": [50365, 865, 13, 50383], "temperature": 0.0, "avg_logprob": -0.17253871191115605, "compression_ratio": 1.5669781931464175, "no_speech_prob": 1.5133981307730027e-12}, {"id": 48, "seek": 18240, "start": 182.88, "end": 192.9, "text": " I mean, to appreciate why this bubble metaphor, what they call the sphere pop calculus, is so revolutionary, we actually need to take a quick detour back to the 1930s.", "tokens": [50389, 286, 914, 11, 281, 4449, 983, 341, 12212, 19157, 11, 437, 436, 818, 264, 16687, 1665, 33400, 11, 307, 370, 22687, 11, 321, 767, 643, 281, 747, 257, 1702, 1141, 396, 646, 281, 264, 22350, 82, 13, 50890], "temperature": 0.0, "avg_logprob": -0.17253871191115605, "compression_ratio": 1.5669781931464175, "no_speech_prob": 1.5133981307730027e-12}, {"id": 49, "seek": 18240, "start": 192.98000000000002, "end": 193.20000000000002, "text": " Okay.", "tokens": [50894, 1033, 13, 50905], "temperature": 0.0, "avg_logprob": -0.17253871191115605, "compression_ratio": 1.5669781931464175, "no_speech_prob": 1.5133981307730027e-12}, {"id": 50, "seek": 18240, "start": 193.3, "end": 193.82, "text": " Time travel.", "tokens": [50910, 6161, 3147, 13, 50936], "temperature": 0.0, "avg_logprob": -0.17253871191115605, "compression_ratio": 1.5669781931464175, "no_speech_prob": 1.5133981307730027e-12}, {"id": 51, "seek": 18240, "start": 194.06, "end": 194.36, "text": " I'm in.", "tokens": [50948, 286, 478, 294, 13, 50963], "temperature": 0.0, "avg_logprob": -0.17253871191115605, "compression_ratio": 1.5669781931464175, "no_speech_prob": 1.5133981307730027e-12}, {"id": 52, "seek": 18240, "start": 194.8, "end": 199.38, "text": " So a mathematician named Alonzo Church introduced something called the lambda calculus.", "tokens": [50985, 407, 257, 48281, 4926, 967, 266, 4765, 7882, 7268, 746, 1219, 264, 13607, 33400, 13, 51214], "temperature": 0.0, "avg_logprob": -0.17253871191115605, "compression_ratio": 1.5669781931464175, "no_speech_prob": 1.5133981307730027e-12}, {"id": 53, "seek": 18240, "start": 199.58, "end": 199.78, "text": " Right.", "tokens": [51224, 1779, 13, 51234], "temperature": 0.0, "avg_logprob": -0.17253871191115605, "compression_ratio": 1.5669781931464175, "no_speech_prob": 1.5133981307730027e-12}, {"id": 54, "seek": 18240, "start": 200.08, "end": 204.92000000000002, "text": " And this was the mathematical foundation for what would eventually become functional programming.", "tokens": [51249, 400, 341, 390, 264, 18894, 7030, 337, 437, 576, 4728, 1813, 11745, 9410, 13, 51491], "temperature": 0.0, "avg_logprob": -0.17253871191115605, "compression_ratio": 1.5669781931464175, "no_speech_prob": 1.5133981307730027e-12}, {"id": 55, "seek": 18240, "start": 205.3, "end": 211.72, "text": " But Church was trying to formalize logic using paper and pencil and later, you know, early typewriters.", "tokens": [51510, 583, 7882, 390, 1382, 281, 9860, 1125, 9952, 1228, 3035, 293, 10985, 293, 1780, 11, 291, 458, 11, 2440, 2010, 86, 39335, 13, 51831], "temperature": 0.0, "avg_logprob": -0.17253871191115605, "compression_ratio": 1.5669781931464175, "no_speech_prob": 1.5133981307730027e-12}, {"id": 56, "seek": 18240, "start": 211.72, "end": 211.94, "text": " Sure.", "tokens": [51831, 4894, 13, 51842], "temperature": 0.0, "avg_logprob": -0.17253871191115605, "compression_ratio": 1.5669781931464175, "no_speech_prob": 1.5133981307730027e-12}, {"id": 57, "seek": 21194, "start": 211.94, "end": 216.7, "text": " So, by necessity, computation became heavily textual.", "tokens": [50365, 407, 11, 538, 24217, 11, 24903, 3062, 10950, 2487, 901, 13, 50603], "temperature": 0.0, "avg_logprob": -0.119821471552695, "compression_ratio": 1.6019108280254777, "no_speech_prob": 1.2447838983534187e-12}, {"id": 58, "seek": 21194, "start": 217.18, "end": 224.07999999999998, "text": " It was all about abstraction and application, but represented by sequences of characters and endless nested parentheses.", "tokens": [50627, 467, 390, 439, 466, 37765, 293, 3861, 11, 457, 10379, 538, 22978, 295, 4342, 293, 16144, 15646, 292, 34153, 13, 50972], "temperature": 0.0, "avg_logprob": -0.119821471552695, "compression_ratio": 1.6019108280254777, "no_speech_prob": 1.2447838983534187e-12}, {"id": 59, "seek": 21194, "start": 224.44, "end": 226.07999999999998, "text": " Because that was the medium of the time.", "tokens": [50990, 1436, 300, 390, 264, 6399, 295, 264, 565, 13, 51072], "temperature": 0.0, "avg_logprob": -0.119821471552695, "compression_ratio": 1.6019108280254777, "no_speech_prob": 1.2447838983534187e-12}, {"id": 60, "seek": 21194, "start": 226.16, "end": 228.28, "text": " I mean, you had a typewriter, so you wrote code like a manuscript.", "tokens": [51076, 286, 914, 11, 291, 632, 257, 2010, 23681, 11, 370, 291, 4114, 3089, 411, 257, 23928, 13, 51182], "temperature": 0.0, "avg_logprob": -0.119821471552695, "compression_ratio": 1.6019108280254777, "no_speech_prob": 1.2447838983534187e-12}, {"id": 61, "seek": 21194, "start": 228.48, "end": 228.57999999999998, "text": " Yeah.", "tokens": [51192, 865, 13, 51197], "temperature": 0.0, "avg_logprob": -0.119821471552695, "compression_ratio": 1.6019108280254777, "no_speech_prob": 1.2447838983534187e-12}, {"id": 62, "seek": 21194, "start": 228.68, "end": 229.92, "text": " You literally couldn't do it any other way.", "tokens": [51202, 509, 3736, 2809, 380, 360, 309, 604, 661, 636, 13, 51264], "temperature": 0.0, "avg_logprob": -0.119821471552695, "compression_ratio": 1.6019108280254777, "no_speech_prob": 1.2447838983534187e-12}, {"id": 63, "seek": 21194, "start": 230.0, "end": 230.24, "text": " Right.", "tokens": [51268, 1779, 13, 51280], "temperature": 0.0, "avg_logprob": -0.119821471552695, "compression_ratio": 1.6019108280254777, "no_speech_prob": 1.2447838983534187e-12}, {"id": 64, "seek": 21194, "start": 230.36, "end": 239.54, "text": " But the sphere pop calculus, or SPC as they abbreviate it, argues that this textual limitation fundamentally bottlenecked our understanding of computation.", "tokens": [51286, 583, 264, 16687, 1665, 33400, 11, 420, 8420, 34, 382, 436, 35839, 473, 309, 11, 38218, 300, 341, 2487, 901, 27432, 17879, 44641, 44118, 527, 3701, 295, 24903, 13, 51745], "temperature": 0.0, "avg_logprob": -0.119821471552695, "compression_ratio": 1.6019108280254777, "no_speech_prob": 1.2447838983534187e-12}, {"id": 65, "seek": 21194, "start": 239.84, "end": 240.16, "text": " Oh, so.", "tokens": [51760, 876, 11, 370, 13, 51776], "temperature": 0.0, "avg_logprob": -0.119821471552695, "compression_ratio": 1.6019108280254777, "no_speech_prob": 1.2447838983534187e-12}, {"id": 66, "seek": 24016, "start": 240.16, "end": 245.4, "text": " It takes the lambda calculus and transforms it from a flat line of text into three-dimensional geometry.", "tokens": [50365, 467, 2516, 264, 13607, 33400, 293, 35592, 309, 490, 257, 4962, 1622, 295, 2487, 666, 1045, 12, 18759, 18426, 13, 50627], "temperature": 0.0, "avg_logprob": -0.0897630254427592, "compression_ratio": 1.1685393258426966, "no_speech_prob": 1.6584998348626034e-12}, {"id": 67, "seek": 24540, "start": 245.4, "end": 251.0, "text": " Okay, so instead of hitting the bracket key on my keyboard to open a function, I'm dealing with something physical.", "tokens": [50365, 1033, 11, 370, 2602, 295, 8850, 264, 16904, 2141, 322, 452, 10186, 281, 1269, 257, 2445, 11, 286, 478, 6260, 365, 746, 4001, 13, 50645], "temperature": 0.0, "avg_logprob": -0.1929076611995697, "compression_ratio": 1.1634615384615385, "no_speech_prob": 1.7281989641432238e-12}, {"id": 68, "seek": 24540, "start": 251.22, "end": 251.32, "text": " Yeah.", "tokens": [50656, 865, 13, 50661], "temperature": 0.0, "avg_logprob": -0.1929076611995697, "compression_ratio": 1.1634615384615385, "no_speech_prob": 1.7281989641432238e-12}, {"id": 69, "seek": 25132, "start": 251.32, "end": 252.9, "text": " And interacting with geometric scopes.", "tokens": [50365, 400, 18017, 365, 33246, 795, 30545, 13, 50444], "temperature": 0.0, "avg_logprob": -0.2509185430165884, "compression_ratio": 1.5208333333333333, "no_speech_prob": 1.585647737244178e-12}, {"id": 70, "seek": 25132, "start": 253.04, "end": 253.51999999999998, "text": " Exactly.", "tokens": [50451, 7587, 13, 50475], "temperature": 0.0, "avg_logprob": -0.2509185430165884, "compression_ratio": 1.5208333333333333, "no_speech_prob": 1.585647737244178e-12}, {"id": 71, "seek": 25132, "start": 254.07999999999998, "end": 256.24, "text": " The paper introduces two core primitives.", "tokens": [50503, 440, 3035, 31472, 732, 4965, 2886, 38970, 13, 50611], "temperature": 0.0, "avg_logprob": -0.2509185430165884, "compression_ratio": 1.5208333333333333, "no_speech_prob": 1.585647737244178e-12}, {"id": 72, "seek": 25132, "start": 256.24, "end": 257.59999999999997, "text": " The first is the sphere.", "tokens": [50611, 440, 700, 307, 264, 16687, 13, 50679], "temperature": 0.0, "avg_logprob": -0.2509185430165884, "compression_ratio": 1.5208333333333333, "no_speech_prob": 1.585647737244178e-12}, {"id": 73, "seek": 25132, "start": 258.0, "end": 260.06, "text": " Think of the sphere as the act of abstraction.", "tokens": [50699, 6557, 295, 264, 16687, 382, 264, 605, 295, 37765, 13, 50802], "temperature": 0.0, "avg_logprob": -0.2509185430165884, "compression_ratio": 1.5208333333333333, "no_speech_prob": 1.585647737244178e-12}, {"id": 74, "seek": 25132, "start": 260.59999999999997, "end": 266.68, "text": " You are drawing a physical geometric boundary around a space of computation, basically entering a bubble.", "tokens": [50829, 509, 366, 6316, 257, 4001, 33246, 12866, 926, 257, 1901, 295, 24903, 11, 1936, 11104, 257, 12212, 13, 51133], "temperature": 0.0, "avg_logprob": -0.2509185430165884, "compression_ratio": 1.5208333333333333, "no_speech_prob": 1.585647737244178e-12}, {"id": 75, "seek": 25132, "start": 266.82, "end": 267.78, "text": " Okay, let's unpack this.", "tokens": [51140, 1033, 11, 718, 311, 26699, 341, 13, 51188], "temperature": 0.0, "avg_logprob": -0.2509185430165884, "compression_ratio": 1.5208333333333333, "no_speech_prob": 1.585647737244178e-12}, {"id": 76, "seek": 26778, "start": 267.78, "end": 273.26, "text": " It's like, okay, think about exploring a map in a massive open world video game.", "tokens": [50365, 467, 311, 411, 11, 1392, 11, 519, 466, 12736, 257, 4471, 294, 257, 5994, 1269, 1002, 960, 1216, 13, 50639], "temperature": 0.0, "avg_logprob": -0.17911081314086913, "compression_ratio": 1.4702970297029703, "no_speech_prob": 1.8468531825382994e-12}, {"id": 77, "seek": 26778, "start": 273.34, "end": 273.59999999999997, "text": " Sure.", "tokens": [50643, 4894, 13, 50656], "temperature": 0.0, "avg_logprob": -0.17911081314086913, "compression_ratio": 1.4702970297029703, "no_speech_prob": 1.8468531825382994e-12}, {"id": 78, "seek": 26778, "start": 273.9, "end": 274.11999999999995, "text": " Yeah.", "tokens": [50671, 865, 13, 50682], "temperature": 0.0, "avg_logprob": -0.17911081314086913, "compression_ratio": 1.4702970297029703, "no_speech_prob": 1.8468531825382994e-12}, {"id": 79, "seek": 26778, "start": 274.38, "end": 278.47999999999996, "text": " A sphere would be like unlocking a new dungeon.", "tokens": [50695, 316, 16687, 576, 312, 411, 49620, 257, 777, 27919, 13, 50900], "temperature": 0.0, "avg_logprob": -0.17911081314086913, "compression_ratio": 1.4702970297029703, "no_speech_prob": 1.8468531825382994e-12}, {"id": 80, "seek": 26778, "start": 279.02, "end": 284.88, "text": " That specific rune has its own physical rules, its own isolated environment, its own inventory, right?", "tokens": [50927, 663, 2685, 1190, 68, 575, 1080, 1065, 4001, 4474, 11, 1080, 1065, 14621, 2823, 11, 1080, 1065, 14228, 11, 558, 30, 51220], "temperature": 0.0, "avg_logprob": -0.17911081314086913, "compression_ratio": 1.4702970297029703, "no_speech_prob": 1.8468531825382994e-12}, {"id": 81, "seek": 26778, "start": 285.32, "end": 287.79999999999995, "text": " Entering it is an extraction from the main world map.", "tokens": [51242, 10399, 278, 309, 307, 364, 30197, 490, 264, 2135, 1002, 4471, 13, 51366], "temperature": 0.0, "avg_logprob": -0.17911081314086913, "compression_ratio": 1.4702970297029703, "no_speech_prob": 1.8468531825382994e-12}, {"id": 82, "seek": 28780, "start": 287.8, "end": 288.90000000000003, "text": " That's a great way to look at it.", "tokens": [50365, 663, 311, 257, 869, 636, 281, 574, 412, 309, 13, 50420], "temperature": 0.0, "avg_logprob": -0.20073272705078124, "compression_ratio": 1.3533834586466165, "no_speech_prob": 1.6356238195444628e-12}, {"id": 83, "seek": 28780, "start": 289.04, "end": 290.56, "text": " And the second primitive is the pop.", "tokens": [50427, 400, 264, 1150, 28540, 307, 264, 1665, 13, 50503], "temperature": 0.0, "avg_logprob": -0.20073272705078124, "compression_ratio": 1.3533834586466165, "no_speech_prob": 1.6356238195444628e-12}, {"id": 84, "seek": 28780, "start": 290.88, "end": 296.24, "text": " If the sphere is abstraction, the pop is application, or what mathematicians would call beta reduction.", "tokens": [50519, 759, 264, 16687, 307, 37765, 11, 264, 1665, 307, 3861, 11, 420, 437, 32811, 2567, 576, 818, 9861, 11004, 13, 50787], "temperature": 0.0, "avg_logprob": -0.20073272705078124, "compression_ratio": 1.3533834586466165, "no_speech_prob": 1.6356238195444628e-12}, {"id": 85, "seek": 28780, "start": 296.54, "end": 296.76, "text": " Okay.", "tokens": [50802, 1033, 13, 50813], "temperature": 0.0, "avg_logprob": -0.20073272705078124, "compression_ratio": 1.3533834586466165, "no_speech_prob": 1.6356238195444628e-12}, {"id": 86, "seek": 29676, "start": 296.76, "end": 301.86, "text": " It is the act of collapsing that sphere with a specific argument to produce a result.", "tokens": [50365, 467, 307, 264, 605, 295, 45339, 300, 16687, 365, 257, 2685, 6770, 281, 5258, 257, 1874, 13, 50620], "temperature": 0.0, "avg_logprob": -0.06487370085442203, "compression_ratio": 1.6147540983606556, "no_speech_prob": 1.721450889821674e-12}, {"id": 87, "seek": 29676, "start": 301.86, "end": 320.68, "text": " So, carrying the video game analogy forward, popping would be like detonating a highly specific required item, like, I don't know, a skeleton key or bomb inside that dungeon, which instantly collapses the entire room into a single piece of usable data, like loot, that you carry back out into the main world.", "tokens": [50620, 407, 11, 9792, 264, 960, 1216, 21663, 2128, 11, 18374, 576, 312, 411, 39920, 990, 257, 5405, 2685, 4739, 3174, 11, 411, 11, 286, 500, 380, 458, 11, 257, 25204, 2141, 420, 7851, 1854, 300, 27919, 11, 597, 13518, 48765, 264, 2302, 1808, 666, 257, 2167, 2522, 295, 29975, 1412, 11, 411, 26206, 11, 300, 291, 3985, 646, 484, 666, 264, 2135, 1002, 13, 51561], "temperature": 0.0, "avg_logprob": -0.06487370085442203, "compression_ratio": 1.6147540983606556, "no_speech_prob": 1.721450889821674e-12}, {"id": 88, "seek": 32068, "start": 320.68, "end": 329.82, "text": " The visual is strikingly accurate, actually, and in the sphere pop domain-specific language, the DSL, you actually author these geometric scenes.", "tokens": [50365, 440, 5056, 307, 18559, 356, 8559, 11, 767, 11, 293, 294, 264, 16687, 1665, 9274, 12, 29258, 2856, 11, 264, 15816, 43, 11, 291, 767, 3793, 613, 33246, 8026, 13, 50822], "temperature": 0.0, "avg_logprob": -0.13364909944080172, "compression_ratio": 1.6278195488721805, "no_speech_prob": 1.4437483326912304e-12}, {"id": 89, "seek": 32068, "start": 330.04, "end": 332.74, "text": " Programmers aren't writing traditional lines of code anymore.", "tokens": [50833, 8338, 18552, 3212, 380, 3579, 5164, 3876, 295, 3089, 3602, 13, 50968], "temperature": 0.0, "avg_logprob": -0.13364909944080172, "compression_ratio": 1.6278195488721805, "no_speech_prob": 1.4437483326912304e-12}, {"id": 90, "seek": 32068, "start": 332.84000000000003, "end": 333.5, "text": " What are they doing instead?", "tokens": [50973, 708, 366, 436, 884, 2602, 30, 51006], "temperature": 0.0, "avg_logprob": -0.13364909944080172, "compression_ratio": 1.6278195488721805, "no_speech_prob": 1.4437483326912304e-12}, {"id": 91, "seek": 32068, "start": 333.72, "end": 342.04, "text": " They're using spatial commands, things like at scene, sphere, pop, and burst, to choreograph a geometric event.", "tokens": [51017, 814, 434, 1228, 23598, 16901, 11, 721, 411, 412, 4145, 11, 16687, 11, 1665, 11, 293, 12712, 11, 281, 14625, 3108, 257, 33246, 2280, 13, 51433], "temperature": 0.0, "avg_logprob": -0.13364909944080172, "compression_ratio": 1.6278195488721805, "no_speech_prob": 1.4437483326912304e-12}, {"id": 92, "seek": 32068, "start": 342.6, "end": 346.32, "text": " The authors describe this computationally as a coherence foam.", "tokens": [51461, 440, 16552, 6786, 341, 24903, 379, 382, 257, 26528, 655, 12958, 13, 51647], "temperature": 0.0, "avg_logprob": -0.13364909944080172, "compression_ratio": 1.6278195488721805, "no_speech_prob": 1.4437483326912304e-12}, {"id": 93, "seek": 32068, "start": 346.44, "end": 347.62, "text": " Coherence foam, okay.", "tokens": [51653, 3066, 511, 655, 12958, 11, 1392, 13, 51712], "temperature": 0.0, "avg_logprob": -0.13364909944080172, "compression_ratio": 1.6278195488721805, "no_speech_prob": 1.4437483326912304e-12}, {"id": 94, "seek": 34762, "start": 347.62, "end": 355.54, "text": " And in categorical math terms, they represent sphere and pop as the exponential and evaluation morphisms within a pre-chief topos.", "tokens": [50365, 400, 294, 19250, 804, 5221, 2115, 11, 436, 2906, 16687, 293, 1665, 382, 264, 21510, 293, 13344, 25778, 13539, 1951, 257, 659, 12, 30189, 1192, 329, 13, 50761], "temperature": 0.0, "avg_logprob": -0.10072257939506979, "compression_ratio": 1.7098765432098766, "no_speech_prob": 1.7013979201202512e-12}, {"id": 95, "seek": 34762, "start": 355.72, "end": 356.68, "text": " Whoa, whoa, hold on.", "tokens": [50770, 7521, 11, 13310, 11, 1797, 322, 13, 50818], "temperature": 0.0, "avg_logprob": -0.10072257939506979, "compression_ratio": 1.7098765432098766, "no_speech_prob": 1.7013979201202512e-12}, {"id": 96, "seek": 34762, "start": 356.74, "end": 360.96, "text": " We promised the listener we'd leave the heavy jargon at the door, or at least, you know, translate it.", "tokens": [50821, 492, 10768, 264, 31569, 321, 1116, 1856, 264, 4676, 15181, 10660, 412, 264, 2853, 11, 420, 412, 1935, 11, 291, 458, 11, 13799, 309, 13, 51032], "temperature": 0.0, "avg_logprob": -0.10072257939506979, "compression_ratio": 1.7098765432098766, "no_speech_prob": 1.7013979201202512e-12}, {"id": 97, "seek": 34762, "start": 361.08, "end": 362.7, "text": " What on earth is a pre-chief topos?", "tokens": [51038, 708, 322, 4120, 307, 257, 659, 12, 30189, 1192, 329, 30, 51119], "temperature": 0.0, "avg_logprob": -0.10072257939506979, "compression_ratio": 1.7098765432098766, "no_speech_prob": 1.7013979201202512e-12}, {"id": 98, "seek": 34762, "start": 362.84000000000003, "end": 363.72, "text": " Fair enough, fair enough.", "tokens": [51126, 12157, 1547, 11, 3143, 1547, 13, 51170], "temperature": 0.0, "avg_logprob": -0.10072257939506979, "compression_ratio": 1.7098765432098766, "no_speech_prob": 1.7013979201202512e-12}, {"id": 99, "seek": 34762, "start": 363.84000000000003, "end": 369.16, "text": " Okay, a topos is essentially a mathematical universe where certain types of logic behave perfectly.", "tokens": [51176, 1033, 11, 257, 1192, 329, 307, 4476, 257, 18894, 6445, 689, 1629, 3467, 295, 9952, 15158, 6239, 13, 51442], "temperature": 0.0, "avg_logprob": -0.10072257939506979, "compression_ratio": 1.7098765432098766, "no_speech_prob": 1.7013979201202512e-12}, {"id": 100, "seek": 34762, "start": 369.16, "end": 377.26, "text": " A pre-chief topos is a specific fabric of this universe where you can smoothly glue localized observations together to make global sense.", "tokens": [51442, 316, 659, 12, 30189, 1192, 329, 307, 257, 2685, 7253, 295, 341, 6445, 689, 291, 393, 19565, 8998, 44574, 18163, 1214, 281, 652, 4338, 2020, 13, 51847], "temperature": 0.0, "avg_logprob": -0.10072257939506979, "compression_ratio": 1.7098765432098766, "no_speech_prob": 1.7013979201202512e-12}, {"id": 101, "seek": 37726, "start": 377.26, "end": 378.38, "text": " You glue them together.", "tokens": [50365, 509, 8998, 552, 1214, 13, 50421], "temperature": 0.0, "avg_logprob": -0.12973713263487205, "compression_ratio": 1.6223175965665235, "no_speech_prob": 1.6420273344155967e-12}, {"id": 102, "seek": 37726, "start": 378.58, "end": 379.8, "text": " Yeah, imagine a weather map.", "tokens": [50431, 865, 11, 3811, 257, 5503, 4471, 13, 50492], "temperature": 0.0, "avg_logprob": -0.12973713263487205, "compression_ratio": 1.6223175965665235, "no_speech_prob": 1.6420273344155967e-12}, {"id": 103, "seek": 37726, "start": 380.34, "end": 385.62, "text": " You have local weather stations' bubbles, essentially measuring temperature and pressure in isolated areas.", "tokens": [50519, 509, 362, 2654, 5503, 13390, 6, 16295, 11, 4476, 13389, 4292, 293, 3321, 294, 14621, 3179, 13, 50783], "temperature": 0.0, "avg_logprob": -0.12973713263487205, "compression_ratio": 1.6223175965665235, "no_speech_prob": 1.6420273344155967e-12}, {"id": 104, "seek": 37726, "start": 385.74, "end": 385.92, "text": " Right.", "tokens": [50789, 1779, 13, 50798], "temperature": 0.0, "avg_logprob": -0.12973713263487205, "compression_ratio": 1.6223175965665235, "no_speech_prob": 1.6420273344155967e-12}, {"id": 105, "seek": 37726, "start": 386.18, "end": 399.38, "text": " The pre-chief topos is the underlying mathematical structure that allows you to seamlessly overlap all those isolated local bubbles into one coherent global weather system without them contradicting each other.", "tokens": [50811, 440, 659, 12, 30189, 1192, 329, 307, 264, 14217, 18894, 3877, 300, 4045, 291, 281, 38083, 19959, 439, 729, 14621, 2654, 16295, 666, 472, 36239, 4338, 5503, 1185, 1553, 552, 15858, 21490, 1184, 661, 13, 51471], "temperature": 0.0, "avg_logprob": -0.12973713263487205, "compression_ratio": 1.6223175965665235, "no_speech_prob": 1.6420273344155967e-12}, {"id": 106, "seek": 39938, "start": 399.38, "end": 400.86, "text": " Oh, I see the elegance there.", "tokens": [50365, 876, 11, 286, 536, 264, 14459, 719, 456, 13, 50439], "temperature": 0.0, "avg_logprob": -0.1136062496998271, "compression_ratio": 1.4965277777777777, "no_speech_prob": 1.7754445916923212e-12}, {"id": 107, "seek": 39938, "start": 400.94, "end": 401.52, "text": " That makes sense.", "tokens": [50443, 663, 1669, 2020, 13, 50472], "temperature": 0.0, "avg_logprob": -0.1136062496998271, "compression_ratio": 1.4965277777777777, "no_speech_prob": 1.7754445916923212e-12}, {"id": 108, "seek": 39938, "start": 401.7, "end": 401.82, "text": " Yeah.", "tokens": [50481, 865, 13, 50487], "temperature": 0.0, "avg_logprob": -0.1136062496998271, "compression_ratio": 1.4965277777777777, "no_speech_prob": 1.7754445916923212e-12}, {"id": 109, "seek": 39938, "start": 401.84, "end": 402.96, "text": " But let me push back for a second.", "tokens": [50488, 583, 718, 385, 2944, 646, 337, 257, 1150, 13, 50544], "temperature": 0.0, "avg_logprob": -0.1136062496998271, "compression_ratio": 1.4965277777777777, "no_speech_prob": 1.7754445916923212e-12}, {"id": 110, "seek": 39938, "start": 403.2, "end": 403.71999999999997, "text": " Go for it.", "tokens": [50556, 1037, 337, 309, 13, 50582], "temperature": 0.0, "avg_logprob": -0.1136062496998271, "compression_ratio": 1.4965277777777777, "no_speech_prob": 1.7754445916923212e-12}, {"id": 111, "seek": 39938, "start": 403.84, "end": 414.32, "text": " If this just mimics Alonzo Church's old lambda calculus from the 1930s, aren't we just slapping a fancy 3D visualization onto math that already exists?", "tokens": [50588, 759, 341, 445, 12247, 1167, 967, 266, 4765, 7882, 311, 1331, 13607, 33400, 490, 264, 22350, 82, 11, 3212, 380, 321, 445, 8039, 3759, 257, 10247, 805, 35, 25801, 3911, 5221, 300, 1217, 8198, 30, 51112], "temperature": 0.0, "avg_logprob": -0.1136062496998271, "compression_ratio": 1.4965277777777777, "no_speech_prob": 1.7754445916923212e-12}, {"id": 112, "seek": 39938, "start": 414.84, "end": 417.54, "text": " I mean, a weather map looks nice, but it doesn't change the weather.", "tokens": [51138, 286, 914, 11, 257, 5503, 4471, 1542, 1481, 11, 457, 309, 1177, 380, 1319, 264, 5503, 13, 51273], "temperature": 0.0, "avg_logprob": -0.1136062496998271, "compression_ratio": 1.4965277777777777, "no_speech_prob": 1.7754445916923212e-12}, {"id": 113, "seek": 39938, "start": 417.9, "end": 422.76, "text": " What can this geometric foam actually do that my old school Python script can't?", "tokens": [51291, 708, 393, 341, 33246, 12958, 767, 360, 300, 452, 1331, 1395, 15329, 5755, 393, 380, 30, 51534], "temperature": 0.0, "avg_logprob": -0.1136062496998271, "compression_ratio": 1.4965277777777777, "no_speech_prob": 1.7754445916923212e-12}, {"id": 114, "seek": 39938, "start": 422.8, "end": 423.88, "text": " That is the perfect question.", "tokens": [51536, 663, 307, 264, 2176, 1168, 13, 51590], "temperature": 0.0, "avg_logprob": -0.1136062496998271, "compression_ratio": 1.4965277777777777, "no_speech_prob": 1.7754445916923212e-12}, {"id": 115, "seek": 42388, "start": 423.88, "end": 426.88, "text": " If sphere pop were merely a visual skin, it would just be a toy.", "tokens": [50365, 759, 16687, 1665, 645, 17003, 257, 5056, 3178, 11, 309, 576, 445, 312, 257, 12058, 13, 50515], "temperature": 0.0, "avg_logprob": -0.14303039949993754, "compression_ratio": 1.5466101694915255, "no_speech_prob": 2.068028040480563e-12}, {"id": 116, "seek": 42388, "start": 427.88, "end": 437.28, "text": " Where it radically departs from classical text-based programming is in its native ability to handle the chaotic, parallel, and probabilistic nature of the real world.", "tokens": [50565, 2305, 309, 35508, 9110, 82, 490, 13735, 2487, 12, 6032, 9410, 307, 294, 1080, 8470, 3485, 281, 4813, 264, 27013, 11, 8952, 11, 293, 31959, 3142, 3687, 295, 264, 957, 1002, 13, 51035], "temperature": 0.0, "avg_logprob": -0.14303039949993754, "compression_ratio": 1.5466101694915255, "no_speech_prob": 2.068028040480563e-12}, {"id": 117, "seek": 42388, "start": 437.52, "end": 438.86, "text": " Okay, you have my attention.", "tokens": [51047, 1033, 11, 291, 362, 452, 3202, 13, 51114], "temperature": 0.0, "avg_logprob": -0.14303039949993754, "compression_ratio": 1.5466101694915255, "no_speech_prob": 2.068028040480563e-12}, {"id": 118, "seek": 42388, "start": 439.06, "end": 443.14, "text": " Traditional lambda calculus is inherently sequential and deterministic.", "tokens": [51124, 46738, 13607, 33400, 307, 27993, 42881, 293, 15957, 3142, 13, 51328], "temperature": 0.0, "avg_logprob": -0.14303039949993754, "compression_ratio": 1.5466101694915255, "no_speech_prob": 2.068028040480563e-12}, {"id": 119, "seek": 42388, "start": 443.58, "end": 445.68, "text": " One domino falls, then the next.", "tokens": [51350, 1485, 3285, 2982, 8804, 11, 550, 264, 958, 13, 51455], "temperature": 0.0, "avg_logprob": -0.14303039949993754, "compression_ratio": 1.5466101694915255, "no_speech_prob": 2.068028040480563e-12}, {"id": 120, "seek": 44568, "start": 445.68, "end": 454.42, "text": " First, sphere pop introduces two entirely new core geometric primitives to break that limitation, and they are merge and choice.", "tokens": [50365, 2386, 11, 16687, 1665, 31472, 732, 7696, 777, 4965, 33246, 2886, 38970, 281, 1821, 300, 27432, 11, 293, 436, 366, 22183, 293, 3922, 13, 50802], "temperature": 0.0, "avg_logprob": -0.1438022220835966, "compression_ratio": 1.6124567474048443, "no_speech_prob": 1.361580553166375e-12}, {"id": 121, "seek": 44568, "start": 455.06, "end": 462.58, "text": " Wait, but in traditional coding, making two things happen at exactly the same time like concurrency usually results in a crash if they bump into each other.", "tokens": [50834, 3802, 11, 457, 294, 5164, 17720, 11, 1455, 732, 721, 1051, 412, 2293, 264, 912, 565, 411, 23702, 10457, 2673, 3542, 294, 257, 8252, 498, 436, 9961, 666, 1184, 661, 13, 51210], "temperature": 0.0, "avg_logprob": -0.1438022220835966, "compression_ratio": 1.6124567474048443, "no_speech_prob": 1.361580553166375e-12}, {"id": 122, "seek": 44568, "start": 462.96000000000004, "end": 467.68, "text": " How does sphere pop's geometry prevent that collision when merging?", "tokens": [51229, 1012, 775, 16687, 1665, 311, 18426, 4871, 300, 24644, 562, 44559, 30, 51465], "temperature": 0.0, "avg_logprob": -0.1438022220835966, "compression_ratio": 1.6124567474048443, "no_speech_prob": 1.361580553166375e-12}, {"id": 123, "seek": 44568, "start": 467.68, "end": 471.38, "text": " Well, merge acts as parallel or disjunctive composition.", "tokens": [51465, 1042, 11, 22183, 10672, 382, 8952, 420, 717, 10010, 20221, 12686, 13, 51650], "temperature": 0.0, "avg_logprob": -0.1438022220835966, "compression_ratio": 1.6124567474048443, "no_speech_prob": 1.361580553166375e-12}, {"id": 124, "seek": 44568, "start": 471.88, "end": 474.14, "text": " Mathematically, it functions like a categorical tensor.", "tokens": [51675, 15776, 40197, 11, 309, 6828, 411, 257, 19250, 804, 40863, 13, 51788], "temperature": 0.0, "avg_logprob": -0.1438022220835966, "compression_ratio": 1.6124567474048443, "no_speech_prob": 1.361580553166375e-12}, {"id": 125, "seek": 47414, "start": 474.14, "end": 478.94, "text": " It allows two completely independent processes to run alongside each other in the foam.", "tokens": [50365, 467, 4045, 732, 2584, 6695, 7555, 281, 1190, 12385, 1184, 661, 294, 264, 12958, 13, 50605], "temperature": 0.0, "avg_logprob": -0.14612194587444438, "compression_ratio": 1.6677966101694914, "no_speech_prob": 1.5248920832641732e-12}, {"id": 126, "seek": 47414, "start": 479.26, "end": 479.68, "text": " Without crashing.", "tokens": [50621, 9129, 26900, 13, 50642], "temperature": 0.0, "avg_logprob": -0.14612194587444438, "compression_ratio": 1.6677966101694914, "no_speech_prob": 1.5248920832641732e-12}, {"id": 127, "seek": 47414, "start": 479.84, "end": 480.34, "text": " Without crashing.", "tokens": [50650, 9129, 26900, 13, 50675], "temperature": 0.0, "avg_logprob": -0.14612194587444438, "compression_ratio": 1.6677966101694914, "no_speech_prob": 1.5248920832641732e-12}, {"id": 128, "seek": 47414, "start": 480.68, "end": 483.76, "text": " Because it's geometric, it's both associative and commutative.", "tokens": [50692, 1436, 309, 311, 33246, 11, 309, 311, 1293, 4180, 1166, 293, 800, 325, 1166, 13, 50846], "temperature": 0.0, "avg_logprob": -0.14612194587444438, "compression_ratio": 1.6677966101694914, "no_speech_prob": 1.5248920832641732e-12}, {"id": 129, "seek": 47414, "start": 483.91999999999996, "end": 484.08, "text": " Yeah.", "tokens": [50854, 865, 13, 50862], "temperature": 0.0, "avg_logprob": -0.14612194587444438, "compression_ratio": 1.6677966101694914, "no_speech_prob": 1.5248920832641732e-12}, {"id": 130, "seek": 47414, "start": 484.15999999999997, "end": 487.12, "text": " It literally doesn't matter what order you merge the bubbles in.", "tokens": [50866, 467, 3736, 1177, 380, 1871, 437, 1668, 291, 22183, 264, 16295, 294, 13, 51014], "temperature": 0.0, "avg_logprob": -0.14612194587444438, "compression_ratio": 1.6677966101694914, "no_speech_prob": 1.5248920832641732e-12}, {"id": 131, "seek": 47414, "start": 487.36, "end": 495.02, "text": " The system naturally handles them as parallel branches of reality operating at once without a central traffic cop dictating who goes first.", "tokens": [51026, 440, 1185, 8195, 18722, 552, 382, 8952, 14770, 295, 4103, 7447, 412, 1564, 1553, 257, 5777, 6419, 2971, 12569, 990, 567, 1709, 700, 13, 51409], "temperature": 0.0, "avg_logprob": -0.14612194587444438, "compression_ratio": 1.6677966101694914, "no_speech_prob": 1.5248920832641732e-12}, {"id": 132, "seek": 47414, "start": 495.14, "end": 496.24, "text": " Here's where it gets really interesting.", "tokens": [51415, 1692, 311, 689, 309, 2170, 534, 1880, 13, 51470], "temperature": 0.0, "avg_logprob": -0.14612194587444438, "compression_ratio": 1.6677966101694914, "no_speech_prob": 1.5248920832641732e-12}, {"id": 133, "seek": 47414, "start": 496.32, "end": 496.97999999999996, "text": " What about choice?", "tokens": [51474, 708, 466, 3922, 30, 51507], "temperature": 0.0, "avg_logprob": -0.14612194587444438, "compression_ratio": 1.6677966101694914, "no_speech_prob": 1.5248920832641732e-12}, {"id": 134, "seek": 47414, "start": 497.38, "end": 499.34, "text": " Choice is probabilistic branching.", "tokens": [51527, 37080, 307, 31959, 3142, 9819, 278, 13, 51625], "temperature": 0.0, "avg_logprob": -0.14612194587444438, "compression_ratio": 1.6677966101694914, "no_speech_prob": 1.5248920832641732e-12}, {"id": 135, "seek": 49934, "start": 499.34, "end": 507.88, "text": " It allows the program to natively say, take this geometric path with probability P and the other path with probability 1 minus P.", "tokens": [50365, 467, 4045, 264, 1461, 281, 8470, 356, 584, 11, 747, 341, 33246, 3100, 365, 8482, 430, 293, 264, 661, 3100, 365, 8482, 502, 3175, 430, 13, 50792], "temperature": 0.0, "avg_logprob": -0.1536286175251007, "compression_ratio": 1.4947368421052631, "no_speech_prob": 2.0683520000897015e-12}, {"id": 136, "seek": 49934, "start": 508.71999999999997, "end": 513.24, "text": " The source material actually connects this to something called the jury distribution monad.", "tokens": [50834, 440, 4009, 2527, 767, 16967, 341, 281, 746, 1219, 264, 19516, 7316, 1108, 345, 13, 51060], "temperature": 0.0, "avg_logprob": -0.1536286175251007, "compression_ratio": 1.4947368421052631, "no_speech_prob": 2.0683520000897015e-12}, {"id": 137, "seek": 49934, "start": 513.4, "end": 515.78, "text": " Which means what exactly in physical terms?", "tokens": [51068, 3013, 1355, 437, 2293, 294, 4001, 2115, 30, 51187], "temperature": 0.0, "avg_logprob": -0.1536286175251007, "compression_ratio": 1.4947368421052631, "no_speech_prob": 2.0683520000897015e-12}, {"id": 138, "seek": 49934, "start": 515.88, "end": 517.18, "text": " Like for the code?", "tokens": [51192, 1743, 337, 264, 3089, 30, 51257], "temperature": 0.0, "avg_logprob": -0.1536286175251007, "compression_ratio": 1.4947368421052631, "no_speech_prob": 2.0683520000897015e-12}, {"id": 139, "seek": 51718, "start": 517.18, "end": 527.0, "text": " Instead of a program flipping a coin and then acting on the result, the jury monad allows the program to treat the entire probability distribution as a single geometric object.", "tokens": [50365, 7156, 295, 257, 1461, 26886, 257, 11464, 293, 550, 6577, 322, 264, 1874, 11, 264, 19516, 1108, 345, 4045, 264, 1461, 281, 2387, 264, 2302, 8482, 7316, 382, 257, 2167, 33246, 2657, 13, 50856], "temperature": 0.0, "avg_logprob": -0.11801641836933706, "compression_ratio": 1.5829596412556053, "no_speech_prob": 1.7211839592468081e-12}, {"id": 140, "seek": 51718, "start": 527.16, "end": 527.8399999999999, "text": " Wait, what?", "tokens": [50864, 3802, 11, 437, 30, 50898], "temperature": 0.0, "avg_logprob": -0.11801641836933706, "compression_ratio": 1.5829596412556053, "no_speech_prob": 1.7211839592468081e-12}, {"id": 141, "seek": 51718, "start": 528.0, "end": 528.1999999999999, "text": " Yeah.", "tokens": [50906, 865, 13, 50916], "temperature": 0.0, "avg_logprob": -0.11801641836933706, "compression_ratio": 1.5829596412556053, "no_speech_prob": 1.7211839592468081e-12}, {"id": 142, "seek": 51718, "start": 528.7199999999999, "end": 530.4599999999999, "text": " Imagine a spinning roulette wheel.", "tokens": [50942, 11739, 257, 15640, 18450, 36563, 5589, 13, 51029], "temperature": 0.0, "avg_logprob": -0.11801641836933706, "compression_ratio": 1.5829596412556053, "no_speech_prob": 1.7211839592468081e-12}, {"id": 143, "seek": 51718, "start": 530.9399999999999, "end": 537.0, "text": " Traditional code waits for the ball to land, reads the number, and then executes the next line based on that number.", "tokens": [51053, 46738, 3089, 40597, 337, 264, 2594, 281, 2117, 11, 15700, 264, 1230, 11, 293, 550, 4454, 1819, 264, 958, 1622, 2361, 322, 300, 1230, 13, 51356], "temperature": 0.0, "avg_logprob": -0.11801641836933706, "compression_ratio": 1.5829596412556053, "no_speech_prob": 1.7211839592468081e-12}, {"id": 144, "seek": 51718, "start": 537.38, "end": 537.5999999999999, "text": " Right.", "tokens": [51375, 1779, 13, 51386], "temperature": 0.0, "avg_logprob": -0.11801641836933706, "compression_ratio": 1.5829596412556053, "no_speech_prob": 1.7211839592468081e-12}, {"id": 145, "seek": 53760, "start": 537.6, "end": 547.0, "text": " Choice, powered by the jury monad, allows the program to pick up the entire spinning roulette wheel, carry it around, and plug it into other equations before the ball ever lands.", "tokens": [50365, 37080, 11, 17786, 538, 264, 19516, 1108, 345, 11, 4045, 264, 1461, 281, 1888, 493, 264, 2302, 15640, 18450, 36563, 5589, 11, 3985, 309, 926, 11, 293, 5452, 309, 666, 661, 11787, 949, 264, 2594, 1562, 5949, 13, 50835], "temperature": 0.0, "avg_logprob": -0.1089600962261821, "compression_ratio": 1.5612648221343874, "no_speech_prob": 1.50125289803682e-12}, {"id": 146, "seek": 53760, "start": 547.48, "end": 549.72, "text": " You are doing math with the probabilities themselves.", "tokens": [50859, 509, 366, 884, 5221, 365, 264, 33783, 2969, 13, 50971], "temperature": 0.0, "avg_logprob": -0.1089600962261821, "compression_ratio": 1.5612648221343874, "no_speech_prob": 1.50125289803682e-12}, {"id": 147, "seek": 53760, "start": 549.98, "end": 558.9, "text": " So wait, if I'm building an app that queries three different independent databases simultaneously, and each database has a slight chance of tining out or failing,", "tokens": [50984, 407, 1699, 11, 498, 286, 478, 2390, 364, 724, 300, 24109, 1045, 819, 6695, 22380, 16561, 11, 293, 1184, 8149, 575, 257, 4036, 2931, 295, 256, 1760, 484, 420, 18223, 11, 51430], "temperature": 0.0, "avg_logprob": -0.1089600962261821, "compression_ratio": 1.5612648221343874, "no_speech_prob": 1.50125289803682e-12}, {"id": 148, "seek": 55890, "start": 558.9, "end": 563.78, "text": " SpherePOP can natively carry those spinning roulette wheels of probability forward?", "tokens": [50365, 318, 6605, 47, 12059, 393, 8470, 356, 3985, 729, 15640, 18450, 36563, 10046, 295, 8482, 2128, 30, 50609], "temperature": 0.0, "avg_logprob": -0.23710770857961555, "compression_ratio": 1.5204918032786885, "no_speech_prob": 1.5428654447785517e-12}, {"id": 149, "seek": 55890, "start": 564.1, "end": 565.68, "text": " It does more than carry them.", "tokens": [50625, 467, 775, 544, 813, 3985, 552, 13, 50704], "temperature": 0.0, "avg_logprob": -0.23710770857961555, "compression_ratio": 1.5204918032786885, "no_speech_prob": 1.5428654447785517e-12}, {"id": 150, "seek": 55890, "start": 566.04, "end": 568.14, "text": " It aggregates their risk geometrically.", "tokens": [50722, 467, 16743, 1024, 641, 3148, 12956, 81, 984, 13, 50827], "temperature": 0.0, "avg_logprob": -0.23710770857961555, "compression_ratio": 1.5204918032786885, "no_speech_prob": 1.5428654447785517e-12}, {"id": 151, "seek": 55890, "start": 568.84, "end": 573.4599999999999, "text": " This is codified in a vital theorem from the paper called the Independent Channels Lemma.", "tokens": [50862, 639, 307, 17656, 2587, 294, 257, 11707, 20904, 490, 264, 3035, 1219, 264, 40310, 761, 969, 1625, 16905, 1696, 13, 51093], "temperature": 0.0, "avg_logprob": -0.23710770857961555, "compression_ratio": 1.5204918032786885, "no_speech_prob": 1.5428654447785517e-12}, {"id": 152, "seek": 55890, "start": 573.9399999999999, "end": 578.4, "text": " It provides a thermodynamic formula for how risk compounds across merged branches.", "tokens": [51117, 467, 6417, 257, 8810, 34988, 8513, 337, 577, 3148, 21810, 2108, 36427, 14770, 13, 51340], "temperature": 0.0, "avg_logprob": -0.23710770857961555, "compression_ratio": 1.5204918032786885, "no_speech_prob": 1.5428654447785517e-12}, {"id": 153, "seek": 55890, "start": 578.52, "end": 579.4599999999999, "text": " The DOOM formula.", "tokens": [51346, 440, 413, 26345, 8513, 13, 51393], "temperature": 0.0, "avg_logprob": -0.23710770857961555, "compression_ratio": 1.5204918032786885, "no_speech_prob": 1.5428654447785517e-12}, {"id": 154, "seek": 55890, "start": 579.5799999999999, "end": 580.9, "text": " Exactly, the DOOM formula.", "tokens": [51399, 7587, 11, 264, 413, 26345, 8513, 13, 51465], "temperature": 0.0, "avg_logprob": -0.23710770857961555, "compression_ratio": 1.5204918032786885, "no_speech_prob": 1.5428654447785517e-12}, {"id": 155, "seek": 58090, "start": 580.9, "end": 592.1999999999999, "text": " The paper proves that if you have a number of independent channels, and each has a distinct probability of failure, which we can call DOOM, the total probability of systemic DOOM isn't just a simple addition.", "tokens": [50365, 440, 3035, 25019, 300, 498, 291, 362, 257, 1230, 295, 6695, 9235, 11, 293, 1184, 575, 257, 10644, 8482, 295, 7763, 11, 597, 321, 393, 818, 413, 26345, 11, 264, 3217, 8482, 295, 23789, 413, 26345, 1943, 380, 445, 257, 2199, 4500, 13, 50930], "temperature": 0.0, "avg_logprob": -0.09526009395204742, "compression_ratio": 1.7755102040816326, "no_speech_prob": 1.9356517257096417e-12}, {"id": 156, "seek": 58090, "start": 592.62, "end": 592.64, "text": " Right.", "tokens": [50951, 1779, 13, 50952], "temperature": 0.0, "avg_logprob": -0.09526009395204742, "compression_ratio": 1.7755102040816326, "no_speech_prob": 1.9356517257096417e-12}, {"id": 157, "seek": 58090, "start": 592.84, "end": 599.54, "text": " The chance of the entire system failing is one minus the product of the survival probabilities of all the individual channels.", "tokens": [50962, 440, 2931, 295, 264, 2302, 1185, 18223, 307, 472, 3175, 264, 1674, 295, 264, 12559, 33783, 295, 439, 264, 2609, 9235, 13, 51297], "temperature": 0.0, "avg_logprob": -0.09526009395204742, "compression_ratio": 1.7755102040816326, "no_speech_prob": 1.9356517257096417e-12}, {"id": 158, "seek": 58090, "start": 599.6999999999999, "end": 609.3, "text": " Okay, so I calculate the chance that database A survives, multiply it by the chance database B survives, multiply that by database C, and subtract that whole number from one.", "tokens": [51305, 1033, 11, 370, 286, 8873, 264, 2931, 300, 8149, 316, 46231, 11, 12972, 309, 538, 264, 2931, 8149, 363, 46231, 11, 12972, 300, 538, 8149, 383, 11, 293, 16390, 300, 1379, 1230, 490, 472, 13, 51785], "temperature": 0.0, "avg_logprob": -0.09526009395204742, "compression_ratio": 1.7755102040816326, "no_speech_prob": 1.9356517257096417e-12}, {"id": 159, "seek": 58090, "start": 609.34, "end": 609.62, "text": " Yes.", "tokens": [51787, 1079, 13, 51801], "temperature": 0.0, "avg_logprob": -0.09526009395204742, "compression_ratio": 1.7755102040816326, "no_speech_prob": 1.9356517257096417e-12}, {"id": 160, "seek": 60962, "start": 609.62, "end": 616.68, "text": " That gives me the exact thermodynamic math to calculate the risk of my entire system crashing at any given moment.", "tokens": [50365, 663, 2709, 385, 264, 1900, 8810, 34988, 5221, 281, 8873, 264, 3148, 295, 452, 2302, 1185, 26900, 412, 604, 2212, 1623, 13, 50718], "temperature": 0.0, "avg_logprob": -0.13703494029002147, "compression_ratio": 1.5753424657534247, "no_speech_prob": 1.4325113361149389e-12}, {"id": 161, "seek": 60962, "start": 616.88, "end": 617.64, "text": " That's wild.", "tokens": [50728, 663, 311, 4868, 13, 50766], "temperature": 0.0, "avg_logprob": -0.13703494029002147, "compression_ratio": 1.5753424657534247, "no_speech_prob": 1.4325113361149389e-12}, {"id": 162, "seek": 60962, "start": 617.82, "end": 618.18, "text": " It is.", "tokens": [50775, 467, 307, 13, 50793], "temperature": 0.0, "avg_logprob": -0.13703494029002147, "compression_ratio": 1.5753424657534247, "no_speech_prob": 1.4325113361149389e-12}, {"id": 163, "seek": 60962, "start": 618.32, "end": 620.74, "text": " And the philosophical shift here is massive.", "tokens": [50800, 400, 264, 25066, 5513, 510, 307, 5994, 13, 50921], "temperature": 0.0, "avg_logprob": -0.13703494029002147, "compression_ratio": 1.5753424657534247, "no_speech_prob": 1.4325113361149389e-12}, {"id": 164, "seek": 60962, "start": 621.34, "end": 626.5600000000001, "text": " Real thought and real-world computation is never a single line of dominoes falling.", "tokens": [50951, 8467, 1194, 293, 957, 12, 13217, 24903, 307, 1128, 257, 2167, 1622, 295, 3285, 2982, 279, 7440, 13, 51212], "temperature": 0.0, "avg_logprob": -0.13703494029002147, "compression_ratio": 1.5753424657534247, "no_speech_prob": 1.4325113361149389e-12}, {"id": 165, "seek": 60962, "start": 626.96, "end": 631.5600000000001, "text": " It's thousands of branches splitting, calculating probabilities, and merging back together.", "tokens": [51232, 467, 311, 5383, 295, 14770, 30348, 11, 28258, 33783, 11, 293, 44559, 646, 1214, 13, 51462], "temperature": 0.0, "avg_logprob": -0.13703494029002147, "compression_ratio": 1.5753424657534247, "no_speech_prob": 1.4325113361149389e-12}, {"id": 166, "seek": 60962, "start": 631.74, "end": 632.9, "text": " Yeah, life isn't sequential.", "tokens": [51471, 865, 11, 993, 1943, 380, 42881, 13, 51529], "temperature": 0.0, "avg_logprob": -0.13703494029002147, "compression_ratio": 1.5753424657534247, "no_speech_prob": 1.4325113361149389e-12}, {"id": 167, "seek": 60962, "start": 633.2, "end": 633.52, "text": " Right.", "tokens": [51544, 1779, 13, 51560], "temperature": 0.0, "avg_logprob": -0.13703494029002147, "compression_ratio": 1.5753424657534247, "no_speech_prob": 1.4325113361149389e-12}, {"id": 168, "seek": 60962, "start": 633.98, "end": 637.8, "text": " Merge and choice allow developers to architect probability natively.", "tokens": [51583, 6124, 432, 293, 3922, 2089, 8849, 281, 6331, 8482, 8470, 356, 13, 51774], "temperature": 0.0, "avg_logprob": -0.13703494029002147, "compression_ratio": 1.5753424657534247, "no_speech_prob": 1.4325113361149389e-12}, {"id": 169, "seek": 63780, "start": 637.8, "end": 642.8, "text": " You're engineering the likelihood of outcomes in a concurrent chaotic system.", "tokens": [50365, 509, 434, 7043, 264, 22119, 295, 10070, 294, 257, 37702, 27013, 1185, 13, 50615], "temperature": 0.0, "avg_logprob": -0.11579947038130327, "compression_ratio": 1.52, "no_speech_prob": 1.4724506336438736e-12}, {"id": 170, "seek": 63780, "start": 643.02, "end": 648.24, "text": " But, I mean, building these fluid geometric systems only works if things don't constantly bleed into one another.", "tokens": [50626, 583, 11, 286, 914, 11, 2390, 613, 9113, 33246, 3652, 787, 1985, 498, 721, 500, 380, 6460, 28385, 666, 472, 1071, 13, 50887], "temperature": 0.0, "avg_logprob": -0.11579947038130327, "compression_ratio": 1.52, "no_speech_prob": 1.4724506336438736e-12}, {"id": 171, "seek": 63780, "start": 648.4, "end": 648.6999999999999, "text": " Sure.", "tokens": [50895, 4894, 13, 50910], "temperature": 0.0, "avg_logprob": -0.11579947038130327, "compression_ratio": 1.52, "no_speech_prob": 1.4724506336438736e-12}, {"id": 172, "seek": 63780, "start": 648.8599999999999, "end": 656.4399999999999, "text": " If I have all these probabilistic bubbles splitting and merging all over the place, how do I keep the system from devolving into total nonsense?", "tokens": [50918, 759, 286, 362, 439, 613, 31959, 3142, 16295, 30348, 293, 44559, 439, 670, 264, 1081, 11, 577, 360, 286, 1066, 264, 1185, 490, 1905, 401, 798, 666, 3217, 14925, 30, 51297], "temperature": 0.0, "avg_logprob": -0.11579947038130327, "compression_ratio": 1.52, "no_speech_prob": 1.4724506336438736e-12}, {"id": 173, "seek": 65644, "start": 656.44, "end": 665.8800000000001, "text": " Like, if I accidentally merge a bubble that calculates my income tax with a bubble that identifies cat pictures, the system needs a way to protect itself.", "tokens": [50365, 1743, 11, 498, 286, 15715, 22183, 257, 12212, 300, 4322, 1024, 452, 5742, 3366, 365, 257, 12212, 300, 34597, 3857, 5242, 11, 264, 1185, 2203, 257, 636, 281, 2371, 2564, 13, 50837], "temperature": 0.0, "avg_logprob": -0.1525738516519236, "compression_ratio": 1.3759398496240602, "no_speech_prob": 1.5489133413371103e-12}, {"id": 174, "seek": 65644, "start": 666.3000000000001, "end": 667.3000000000001, "text": " There have to be boundaries.", "tokens": [50858, 821, 362, 281, 312, 13180, 13, 50908], "temperature": 0.0, "avg_logprob": -0.1525738516519236, "compression_ratio": 1.3759398496240602, "no_speech_prob": 1.5489133413371103e-12}, {"id": 175, "seek": 66730, "start": 667.3, "end": 673.2199999999999, "text": " And that necessity leads us directly into the 2026 paper, Types as Refusal Structures.", "tokens": [50365, 400, 300, 24217, 6689, 505, 3838, 666, 264, 945, 10880, 3035, 11, 5569, 5190, 382, 16957, 11765, 745, 44513, 13, 50661], "temperature": 0.0, "avg_logprob": -0.13173744643943897, "compression_ratio": 1.6246056782334384, "no_speech_prob": 1.5612918943808118e-12}, {"id": 176, "seek": 66730, "start": 674.0799999999999, "end": 679.5999999999999, "text": " This paper completely dismantles and redefines what a type is in computer science.", "tokens": [50704, 639, 3035, 2584, 30506, 904, 293, 38818, 1652, 437, 257, 2010, 307, 294, 3820, 3497, 13, 50980], "temperature": 0.0, "avg_logprob": -0.13173744643943897, "compression_ratio": 1.6246056782334384, "no_speech_prob": 1.5612918943808118e-12}, {"id": 177, "seek": 66730, "start": 679.64, "end": 682.3, "text": " Usually if I think of a type encoding, it's just a label.", "tokens": [50982, 11419, 498, 286, 519, 295, 257, 2010, 43430, 11, 309, 311, 445, 257, 7645, 13, 51115], "temperature": 0.0, "avg_logprob": -0.13173744643943897, "compression_ratio": 1.6246056782334384, "no_speech_prob": 1.5612918943808118e-12}, {"id": 178, "seek": 66730, "start": 682.62, "end": 686.12, "text": " Like labeling a variable as an integer or a string of text.", "tokens": [51131, 1743, 40244, 257, 7006, 382, 364, 24922, 420, 257, 6798, 295, 2487, 13, 51306], "temperature": 0.0, "avg_logprob": -0.13173744643943897, "compression_ratio": 1.6246056782334384, "no_speech_prob": 1.5612918943808118e-12}, {"id": 179, "seek": 66730, "start": 686.54, "end": 688.74, "text": " The type checker runs before the program even starts.", "tokens": [51327, 440, 2010, 1520, 260, 6676, 949, 264, 1461, 754, 3719, 13, 51437], "temperature": 0.0, "avg_logprob": -0.13173744643943897, "compression_ratio": 1.6246056782334384, "no_speech_prob": 1.5612918943808118e-12}, {"id": 180, "seek": 66730, "start": 688.8199999999999, "end": 690.8399999999999, "text": " Kind of like a spell checker in a word processor.", "tokens": [51441, 9242, 295, 411, 257, 9827, 1520, 260, 294, 257, 1349, 15321, 13, 51542], "temperature": 0.0, "avg_logprob": -0.13173744643943897, "compression_ratio": 1.6246056782334384, "no_speech_prob": 1.5612918943808118e-12}, {"id": 181, "seek": 66730, "start": 691.04, "end": 691.26, "text": " Right.", "tokens": [51552, 1779, 13, 51563], "temperature": 0.0, "avg_logprob": -0.13173744643943897, "compression_ratio": 1.6246056782334384, "no_speech_prob": 1.5612918943808118e-12}, {"id": 182, "seek": 66730, "start": 691.3599999999999, "end": 692.92, "text": " Making sure you didn't typo something.", "tokens": [51568, 14595, 988, 291, 994, 380, 2125, 78, 746, 13, 51646], "temperature": 0.0, "avg_logprob": -0.13173744643943897, "compression_ratio": 1.6246056782334384, "no_speech_prob": 1.5612918943808118e-12}, {"id": 183, "seek": 66730, "start": 693.0799999999999, "end": 693.18, "text": " Yeah.", "tokens": [51654, 865, 13, 51659], "temperature": 0.0, "avg_logprob": -0.13173744643943897, "compression_ratio": 1.6246056782334384, "no_speech_prob": 1.5612918943808118e-12}, {"id": 184, "seek": 66730, "start": 693.24, "end": 695.88, "text": " Making sure I didn't try to multiply the word apple by the number four.", "tokens": [51662, 14595, 988, 286, 994, 380, 853, 281, 12972, 264, 1349, 10606, 538, 264, 1230, 1451, 13, 51794], "temperature": 0.0, "avg_logprob": -0.13173744643943897, "compression_ratio": 1.6246056782334384, "no_speech_prob": 1.5612918943808118e-12}, {"id": 185, "seek": 69588, "start": 695.88, "end": 697.36, "text": " Exactly.", "tokens": [50365, 7587, 13, 50439], "temperature": 0.0, "avg_logprob": -0.18860695740886937, "compression_ratio": 1.5955882352941178, "no_speech_prob": 1.3354505218679535e-12}, {"id": 186, "seek": 69588, "start": 697.98, "end": 699.92, "text": " Traditional type checking is entirely static.", "tokens": [50470, 46738, 2010, 8568, 307, 7696, 13437, 13, 50567], "temperature": 0.0, "avg_logprob": -0.18860695740886937, "compression_ratio": 1.5955882352941178, "no_speech_prob": 1.3354505218679535e-12}, {"id": 187, "seek": 69588, "start": 700.32, "end": 703.04, "text": " But in SpherePop, a program isn't just an expression.", "tokens": [50587, 583, 294, 318, 6605, 38677, 11, 257, 1461, 1943, 380, 445, 364, 6114, 13, 50723], "temperature": 0.0, "avg_logprob": -0.18860695740886937, "compression_ratio": 1.5955882352941178, "no_speech_prob": 1.3354505218679535e-12}, {"id": 188, "seek": 69588, "start": 703.34, "end": 705.36, "text": " It is a physical history of commitments.", "tokens": [50738, 467, 307, 257, 4001, 2503, 295, 26230, 13, 50839], "temperature": 0.0, "avg_logprob": -0.18860695740886937, "compression_ratio": 1.5955882352941178, "no_speech_prob": 1.3354505218679535e-12}, {"id": 189, "seek": 69588, "start": 706.34, "end": 709.04, "text": " The architecture defines four fundamental actions.", "tokens": [50888, 440, 9482, 23122, 1451, 8088, 5909, 13, 51023], "temperature": 0.0, "avg_logprob": -0.18860695740886937, "compression_ratio": 1.5955882352941178, "no_speech_prob": 1.3354505218679535e-12}, {"id": 190, "seek": 69588, "start": 709.86, "end": 716.84, "text": " Pop to open a scope, refuse to block a path, collapse to commit to a value, and bind to compose operations.", "tokens": [51064, 10215, 281, 1269, 257, 11923, 11, 16791, 281, 3461, 257, 3100, 11, 15584, 281, 5599, 281, 257, 2158, 11, 293, 14786, 281, 35925, 7705, 13, 51413], "temperature": 0.0, "avg_logprob": -0.18860695740886937, "compression_ratio": 1.5955882352941178, "no_speech_prob": 1.3354505218679535e-12}, {"id": 191, "seek": 69588, "start": 717.84, "end": 721.72, "text": " In this framework, a type is redefined as a disciplined refusal structure.", "tokens": [51463, 682, 341, 8388, 11, 257, 2010, 307, 38818, 2001, 382, 257, 40061, 48948, 3877, 13, 51657], "temperature": 0.0, "avg_logprob": -0.18860695740886937, "compression_ratio": 1.5955882352941178, "no_speech_prob": 1.3354505218679535e-12}, {"id": 192, "seek": 69588, "start": 722.02, "end": 724.64, "text": " It is an active gatekeeper operating in real time.", "tokens": [51672, 467, 307, 364, 4967, 8539, 23083, 7447, 294, 957, 565, 13, 51803], "temperature": 0.0, "avg_logprob": -0.18860695740886937, "compression_ratio": 1.5955882352941178, "no_speech_prob": 1.3354505218679535e-12}, {"id": 193, "seek": 72464, "start": 724.64, "end": 728.68, "text": " It makes me think of an exclusive VIP nightclub.", "tokens": [50365, 467, 1669, 385, 519, 295, 364, 13005, 29732, 1818, 40607, 13, 50567], "temperature": 0.0, "avg_logprob": -0.161030413499519, "compression_ratio": 1.4147727272727273, "no_speech_prob": 1.3886521056313827e-12}, {"id": 194, "seek": 72464, "start": 728.74, "end": 728.98, "text": " Okay.", "tokens": [50570, 1033, 13, 50582], "temperature": 0.0, "avg_logprob": -0.161030413499519, "compression_ratio": 1.4147727272727273, "no_speech_prob": 1.3886521056313827e-12}, {"id": 195, "seek": 72464, "start": 729.06, "end": 729.68, "text": " I like this.", "tokens": [50586, 286, 411, 341, 13, 50617], "temperature": 0.0, "avg_logprob": -0.161030413499519, "compression_ratio": 1.4147727272727273, "no_speech_prob": 1.3886521056313827e-12}, {"id": 196, "seek": 72464, "start": 729.8, "end": 732.56, "text": " The type is the bouncer standing at the door checking IDs.", "tokens": [50623, 440, 2010, 307, 264, 272, 14296, 4877, 412, 264, 2853, 8568, 48212, 13, 50761], "temperature": 0.0, "avg_logprob": -0.161030413499519, "compression_ratio": 1.4147727272727273, "no_speech_prob": 1.3886521056313827e-12}, {"id": 197, "seek": 72464, "start": 733.0, "end": 738.8, "text": " And the context, the environment of the program, is the history of everyone who has already been admitted to the VIP room.", "tokens": [50783, 400, 264, 4319, 11, 264, 2823, 295, 264, 1461, 11, 307, 264, 2503, 295, 1518, 567, 575, 1217, 668, 14920, 281, 264, 29732, 1808, 13, 51073], "temperature": 0.0, "avg_logprob": -0.161030413499519, "compression_ratio": 1.4147727272727273, "no_speech_prob": 1.3886521056313827e-12}, {"id": 198, "seek": 73880, "start": 738.8, "end": 744.42, "text": " Let's take that bouncer analogy and make it purely mechanical, because that is how dependent types operate in this calculus.", "tokens": [50365, 961, 311, 747, 300, 272, 14296, 21663, 293, 652, 309, 17491, 12070, 11, 570, 300, 307, 577, 12334, 3467, 9651, 294, 341, 33400, 13, 50646], "temperature": 0.0, "avg_logprob": -0.10153873477663312, "compression_ratio": 1.6870748299319729, "no_speech_prob": 1.495629683469224e-12}, {"id": 199, "seek": 73880, "start": 744.9799999999999, "end": 750.12, "text": " Specifically, the paper introduces pi types, which are dependent products, and sigma types, dependent sums.", "tokens": [50674, 26058, 11, 264, 3035, 31472, 3895, 3467, 11, 597, 366, 12334, 3383, 11, 293, 12771, 3467, 11, 12334, 34499, 13, 50931], "temperature": 0.0, "avg_logprob": -0.10153873477663312, "compression_ratio": 1.6870748299319729, "no_speech_prob": 1.495629683469224e-12}, {"id": 200, "seek": 73880, "start": 750.28, "end": 750.4, "text": " Okay.", "tokens": [50939, 1033, 13, 50945], "temperature": 0.0, "avg_logprob": -0.10153873477663312, "compression_ratio": 1.6870748299319729, "no_speech_prob": 1.495629683469224e-12}, {"id": 201, "seek": 73880, "start": 750.4399999999999, "end": 751.9599999999999, "text": " How do those mechanical bouncers work?", "tokens": [50947, 1012, 360, 729, 12070, 15521, 8530, 589, 30, 51023], "temperature": 0.0, "avg_logprob": -0.10153873477663312, "compression_ratio": 1.6870748299319729, "no_speech_prob": 1.495629683469224e-12}, {"id": 202, "seek": 73880, "start": 752.2199999999999, "end": 755.06, "text": " A pi type acts as a universal repair operator.", "tokens": [51036, 316, 3895, 2010, 10672, 382, 257, 11455, 10535, 12973, 13, 51178], "temperature": 0.0, "avg_logprob": -0.10153873477663312, "compression_ratio": 1.6870748299319729, "no_speech_prob": 1.495629683469224e-12}, {"id": 203, "seek": 73880, "start": 755.54, "end": 762.8599999999999, "text": " It essentially guarantees that no matter what valid history you provide, it possesses a uniform method to safely continue the computation.", "tokens": [51202, 467, 4476, 32567, 300, 572, 1871, 437, 7363, 2503, 291, 2893, 11, 309, 17490, 279, 257, 9452, 3170, 281, 11750, 2354, 264, 24903, 13, 51568], "temperature": 0.0, "avg_logprob": -0.10153873477663312, "compression_ratio": 1.6870748299319729, "no_speech_prob": 1.495629683469224e-12}, {"id": 204, "seek": 73880, "start": 763.0, "end": 764.12, "text": " It always knows what to do next.", "tokens": [51575, 467, 1009, 3255, 437, 281, 360, 958, 13, 51631], "temperature": 0.0, "avg_logprob": -0.10153873477663312, "compression_ratio": 1.6870748299319729, "no_speech_prob": 1.495629683469224e-12}, {"id": 205, "seek": 76412, "start": 764.12, "end": 764.72, "text": " Exactly.", "tokens": [50365, 7587, 13, 50395], "temperature": 0.0, "avg_logprob": -0.18934056599934895, "compression_ratio": 1.4343434343434343, "no_speech_prob": 1.5736843252123212e-12}, {"id": 206, "seek": 76412, "start": 765.4, "end": 768.32, "text": " But a sigma type is where the mechanism gets fascinating.", "tokens": [50429, 583, 257, 12771, 2010, 307, 689, 264, 7513, 2170, 10343, 13, 50575], "temperature": 0.0, "avg_logprob": -0.18934056599934895, "compression_ratio": 1.4343434343434343, "no_speech_prob": 1.5736843252123212e-12}, {"id": 207, "seek": 76412, "start": 768.72, "end": 769.88, "text": " It's a witnessed repair.", "tokens": [50595, 467, 311, 257, 21519, 10535, 13, 50653], "temperature": 0.0, "avg_logprob": -0.18934056599934895, "compression_ratio": 1.4343434343434343, "no_speech_prob": 1.5736843252123212e-12}, {"id": 208, "seek": 76412, "start": 770.36, "end": 771.96, "text": " It isn't just a bouncer checking a list.", "tokens": [50677, 467, 1943, 380, 445, 257, 272, 14296, 8568, 257, 1329, 13, 50757], "temperature": 0.0, "avg_logprob": -0.18934056599934895, "compression_ratio": 1.4343434343434343, "no_speech_prob": 1.5736843252123212e-12}, {"id": 209, "seek": 76412, "start": 772.5, "end": 781.16, "text": " Think of a sigma type as a highly complex physical lock that cannot turn unless the previous key has literally reconfigured the tumblers.", "tokens": [50784, 6557, 295, 257, 12771, 2010, 382, 257, 5405, 3997, 4001, 4017, 300, 2644, 1261, 5969, 264, 3894, 2141, 575, 3736, 9993, 20646, 3831, 264, 42994, 11977, 13, 51217], "temperature": 0.0, "avg_logprob": -0.18934056599934895, "compression_ratio": 1.4343434343434343, "no_speech_prob": 1.5736843252123212e-12}, {"id": 210, "seek": 76412, "start": 781.72, "end": 782.3, "text": " Wait, really?", "tokens": [51245, 3802, 11, 534, 30, 51274], "temperature": 0.0, "avg_logprob": -0.18934056599934895, "compression_ratio": 1.4343434343434343, "no_speech_prob": 1.5736843252123212e-12}, {"id": 211, "seek": 78230, "start": 782.3, "end": 789.0799999999999, "text": " Yes, the geometry of the first data point, the witness, physically alters the shape of the hole for the next data point.", "tokens": [50365, 1079, 11, 264, 18426, 295, 264, 700, 1412, 935, 11, 264, 7286, 11, 9762, 419, 1559, 264, 3909, 295, 264, 5458, 337, 264, 958, 1412, 935, 13, 50704], "temperature": 0.0, "avg_logprob": -0.12530613812533292, "compression_ratio": 1.7793594306049823, "no_speech_prob": 1.4439612699979065e-12}, {"id": 212, "seek": 78230, "start": 789.2199999999999, "end": 794.88, "text": " So the second piece of data's entry entirely depends on the physical presence and shape of the first piece of data.", "tokens": [50711, 407, 264, 1150, 2522, 295, 1412, 311, 8729, 7696, 5946, 322, 264, 4001, 6814, 293, 3909, 295, 264, 700, 2522, 295, 1412, 13, 50994], "temperature": 0.0, "avg_logprob": -0.12530613812533292, "compression_ratio": 1.7793594306049823, "no_speech_prob": 1.4439612699979065e-12}, {"id": 213, "seek": 78230, "start": 794.9799999999999, "end": 795.4, "text": " Exactly.", "tokens": [50999, 7587, 13, 51020], "temperature": 0.0, "avg_logprob": -0.12530613812533292, "compression_ratio": 1.7793594306049823, "no_speech_prob": 1.4439612699979065e-12}, {"id": 214, "seek": 78230, "start": 796.0799999999999, "end": 799.78, "text": " And this mechanism is how identity types function in SpherePop.", "tokens": [51054, 400, 341, 7513, 307, 577, 6575, 3467, 2445, 294, 318, 6605, 38677, 13, 51239], "temperature": 0.0, "avg_logprob": -0.12530613812533292, "compression_ratio": 1.7793594306049823, "no_speech_prob": 1.4439612699979065e-12}, {"id": 215, "seek": 78230, "start": 800.42, "end": 802.8199999999999, "text": " Identity types express controlled substitutability.", "tokens": [51271, 25905, 507, 3467, 5109, 10164, 26441, 325, 2310, 13, 51391], "temperature": 0.0, "avg_logprob": -0.12530613812533292, "compression_ratio": 1.7793594306049823, "no_speech_prob": 1.4439612699979065e-12}, {"id": 216, "seek": 78230, "start": 803.3399999999999, "end": 810.88, "text": " They're repair paths proving that one history fragment can seamlessly replace another without violating the physical geometry of the lock.", "tokens": [51417, 814, 434, 10535, 14518, 27221, 300, 472, 2503, 26424, 393, 38083, 7406, 1071, 1553, 42201, 264, 4001, 18426, 295, 264, 4017, 13, 51794], "temperature": 0.0, "avg_logprob": -0.12530613812533292, "compression_ratio": 1.7793594306049823, "no_speech_prob": 1.4439612699979065e-12}, {"id": 217, "seek": 81088, "start": 810.88, "end": 816.7, "text": " The paper mentions that this active gatekeeper can return one of three verdicts when evaluating a new piece of data.", "tokens": [50365, 440, 3035, 23844, 300, 341, 4967, 8539, 23083, 393, 2736, 472, 295, 1045, 33957, 82, 562, 27479, 257, 777, 2522, 295, 1412, 13, 50656], "temperature": 0.0, "avg_logprob": -0.13372050482651282, "compression_ratio": 1.6176470588235294, "no_speech_prob": 1.6487981769827686e-12}, {"id": 218, "seek": 81088, "start": 817.32, "end": 820.0, "text": " It can admit, refuse, or defer.", "tokens": [50687, 467, 393, 9796, 11, 16791, 11, 420, 25704, 13, 50821], "temperature": 0.0, "avg_logprob": -0.13372050482651282, "compression_ratio": 1.6176470588235294, "no_speech_prob": 1.6487981769827686e-12}, {"id": 219, "seek": 81088, "start": 820.38, "end": 820.68, "text": " Right.", "tokens": [50840, 1779, 13, 50855], "temperature": 0.0, "avg_logprob": -0.13372050482651282, "compression_ratio": 1.6176470588235294, "no_speech_prob": 1.6487981769827686e-12}, {"id": 220, "seek": 81088, "start": 820.88, "end": 823.78, "text": " Now, I understand admitting data, and I understand refusing data.", "tokens": [50865, 823, 11, 286, 1223, 44056, 1412, 11, 293, 286, 1223, 37289, 1412, 13, 51010], "temperature": 0.0, "avg_logprob": -0.13372050482651282, "compression_ratio": 1.6176470588235294, "no_speech_prob": 1.6487981769827686e-12}, {"id": 221, "seek": 81088, "start": 823.86, "end": 830.72, "text": " Like, if I try to push a cat picture into a math equation, the tumblers don't align, the lock refuses to turn, and that history is permanently blocked.", "tokens": [51014, 1743, 11, 498, 286, 853, 281, 2944, 257, 3857, 3036, 666, 257, 5221, 5367, 11, 264, 42994, 11977, 500, 380, 7975, 11, 264, 4017, 33222, 281, 1261, 11, 293, 300, 2503, 307, 24042, 15470, 13, 51357], "temperature": 0.0, "avg_logprob": -0.13372050482651282, "compression_ratio": 1.6176470588235294, "no_speech_prob": 1.6487981769827686e-12}, {"id": 222, "seek": 81088, "start": 831.04, "end": 833.36, "text": " But I really want to challenge the defer verdict.", "tokens": [51373, 583, 286, 534, 528, 281, 3430, 264, 25704, 33957, 13, 51489], "temperature": 0.0, "avg_logprob": -0.13372050482651282, "compression_ratio": 1.6176470588235294, "no_speech_prob": 1.6487981769827686e-12}, {"id": 223, "seek": 81088, "start": 833.72, "end": 834.02, "text": " Ew.", "tokens": [51507, 28101, 13, 51522], "temperature": 0.0, "avg_logprob": -0.13372050482651282, "compression_ratio": 1.6176470588235294, "no_speech_prob": 1.6487981769827686e-12}, {"id": 224, "seek": 81088, "start": 834.54, "end": 835.6, "text": " Why is that?", "tokens": [51548, 1545, 307, 300, 30, 51601], "temperature": 0.0, "avg_logprob": -0.13372050482651282, "compression_ratio": 1.6176470588235294, "no_speech_prob": 1.6487981769827686e-12}, {"id": 225, "seek": 83560, "start": 835.6, "end": 838.5400000000001, "text": " Why would a computer program ever defer an error?", "tokens": [50365, 1545, 576, 257, 3820, 1461, 1562, 25704, 364, 6713, 30, 50512], "temperature": 0.0, "avg_logprob": -0.13979049644084893, "compression_ratio": 1.5582191780821917, "no_speech_prob": 1.2498081996409338e-12}, {"id": 226, "seek": 83560, "start": 839.3000000000001, "end": 842.82, "text": " If something is wrong, shouldn't it just crash or reject it immediately?", "tokens": [50550, 759, 746, 307, 2085, 11, 4659, 380, 309, 445, 8252, 420, 8248, 309, 4258, 30, 50726], "temperature": 0.0, "avg_logprob": -0.13979049644084893, "compression_ratio": 1.5582191780821917, "no_speech_prob": 1.2498081996409338e-12}, {"id": 227, "seek": 83560, "start": 843.4200000000001, "end": 846.1, "text": " Isn't suspending a problem incredibly dangerous?", "tokens": [50756, 6998, 380, 6535, 2029, 257, 1154, 6252, 5795, 30, 50890], "temperature": 0.0, "avg_logprob": -0.13979049644084893, "compression_ratio": 1.5582191780821917, "no_speech_prob": 1.2498081996409338e-12}, {"id": 228, "seek": 83560, "start": 846.62, "end": 850.02, "text": " That touches on the roots of SpherePop and advanced theorem proving.", "tokens": [50916, 663, 17431, 322, 264, 10669, 295, 318, 6605, 38677, 293, 7339, 20904, 27221, 13, 51086], "temperature": 0.0, "avg_logprob": -0.13979049644084893, "compression_ratio": 1.5582191780821917, "no_speech_prob": 1.2498081996409338e-12}, {"id": 229, "seek": 83560, "start": 850.02, "end": 861.0, "text": " In a highly complex concurrent system, you frequently encounter situations where the system simply doesn't have enough geometric information yet to know if a continuation is valid.", "tokens": [51086, 682, 257, 5405, 3997, 37702, 1185, 11, 291, 10374, 8593, 6851, 689, 264, 1185, 2935, 1177, 380, 362, 1547, 33246, 1589, 1939, 281, 458, 498, 257, 29357, 307, 7363, 13, 51635], "temperature": 0.0, "avg_logprob": -0.13979049644084893, "compression_ratio": 1.5582191780821917, "no_speech_prob": 1.2498081996409338e-12}, {"id": 230, "seek": 83560, "start": 861.1600000000001, "end": 862.4200000000001, "text": " Because it's running in parallel.", "tokens": [51643, 1436, 309, 311, 2614, 294, 8952, 13, 51706], "temperature": 0.0, "avg_logprob": -0.13979049644084893, "compression_ratio": 1.5582191780821917, "no_speech_prob": 1.2498081996409338e-12}, {"id": 231, "seek": 86242, "start": 862.42, "end": 862.9, "text": " Right.", "tokens": [50365, 1779, 13, 50389], "temperature": 0.0, "avg_logprob": -0.12809742987155914, "compression_ratio": 1.6095238095238096, "no_speech_prob": 1.5858849606795178e-12}, {"id": 232, "seek": 86242, "start": 863.38, "end": 865.38, "text": " The other branches haven't merged in yet.", "tokens": [50413, 440, 661, 14770, 2378, 380, 36427, 294, 1939, 13, 50513], "temperature": 0.0, "avg_logprob": -0.12809742987155914, "compression_ratio": 1.6095238095238096, "no_speech_prob": 1.5858849606795178e-12}, {"id": 233, "seek": 86242, "start": 865.9, "end": 868.5799999999999, "text": " In traditional languages, you're right, the system panics and crashes.", "tokens": [50539, 682, 5164, 8650, 11, 291, 434, 558, 11, 264, 1185, 2462, 1167, 293, 28642, 13, 50673], "temperature": 0.0, "avg_logprob": -0.12809742987155914, "compression_ratio": 1.6095238095238096, "no_speech_prob": 1.5858849606795178e-12}, {"id": 234, "seek": 86242, "start": 868.9599999999999, "end": 872.64, "text": " But in an interactive proof state, you want to suspend that obligation.", "tokens": [50692, 583, 294, 364, 15141, 8177, 1785, 11, 291, 528, 281, 42546, 300, 20326, 13, 50876], "temperature": 0.0, "avg_logprob": -0.12809742987155914, "compression_ratio": 1.6095238095238096, "no_speech_prob": 1.5858849606795178e-12}, {"id": 235, "seek": 86242, "start": 872.8399999999999, "end": 874.56, "text": " Like putting the data in a holding pattern.", "tokens": [50886, 1743, 3372, 264, 1412, 294, 257, 5061, 5102, 13, 50972], "temperature": 0.0, "avg_logprob": -0.12809742987155914, "compression_ratio": 1.6095238095238096, "no_speech_prob": 1.5858849606795178e-12}, {"id": 236, "seek": 86242, "start": 874.66, "end": 875.12, "text": " Exactly.", "tokens": [50977, 7587, 13, 51000], "temperature": 0.0, "avg_logprob": -0.12809742987155914, "compression_ratio": 1.6095238095238096, "no_speech_prob": 1.5858849606795178e-12}, {"id": 237, "seek": 86242, "start": 875.3399999999999, "end": 882.04, "text": " The lock basically says, I cannot turn right now because the first key hasn't arrived from the other side of the system, but I'm not ejecting you.", "tokens": [51011, 440, 4017, 1936, 1619, 11, 286, 2644, 1261, 558, 586, 570, 264, 700, 2141, 6132, 380, 6678, 490, 264, 661, 1252, 295, 264, 1185, 11, 457, 286, 478, 406, 32520, 278, 291, 13, 51346], "temperature": 0.0, "avg_logprob": -0.12809742987155914, "compression_ratio": 1.6095238095238096, "no_speech_prob": 1.5858849606795178e-12}, {"id": 238, "seek": 86242, "start": 882.68, "end": 888.0, "text": " Remain in this suspended state and we'll evaluate the geometry again once the missing history is supplied.", "tokens": [51378, 4080, 491, 294, 341, 23437, 1785, 293, 321, 603, 13059, 264, 18426, 797, 1564, 264, 5361, 2503, 307, 27625, 13, 51644], "temperature": 0.0, "avg_logprob": -0.12809742987155914, "compression_ratio": 1.6095238095238096, "no_speech_prob": 1.5858849606795178e-12}, {"id": 239, "seek": 86242, "start": 888.18, "end": 888.76, "text": " Oh, wow.", "tokens": [51653, 876, 11, 6076, 13, 51682], "temperature": 0.0, "avg_logprob": -0.12809742987155914, "compression_ratio": 1.6095238095238096, "no_speech_prob": 1.5858849606795178e-12}, {"id": 240, "seek": 88876, "start": 888.76, "end": 897.98, "text": " It allows for open histories and the ecological development of proofs over time rather than demanding the entire universe be solved before the very first step is taken.", "tokens": [50365, 467, 4045, 337, 1269, 30631, 293, 264, 31054, 3250, 295, 8177, 82, 670, 565, 2831, 813, 19960, 264, 2302, 6445, 312, 13041, 949, 264, 588, 700, 1823, 307, 2726, 13, 50826], "temperature": 0.0, "avg_logprob": -0.11063796482729109, "compression_ratio": 1.5875486381322956, "no_speech_prob": 1.6169024669512866e-12}, {"id": 241, "seek": 88876, "start": 898.34, "end": 900.4, "text": " But what happens when that lock never turns?", "tokens": [50844, 583, 437, 2314, 562, 300, 4017, 1128, 4523, 30, 50947], "temperature": 0.0, "avg_logprob": -0.11063796482729109, "compression_ratio": 1.5875486381322956, "no_speech_prob": 1.6169024669512866e-12}, {"id": 242, "seek": 88876, "start": 900.86, "end": 903.12, "text": " When those boundaries become absolute walls?", "tokens": [50970, 1133, 729, 13180, 1813, 8236, 7920, 30, 51083], "temperature": 0.0, "avg_logprob": -0.11063796482729109, "compression_ratio": 1.5875486381322956, "no_speech_prob": 1.6169024669512866e-12}, {"id": 243, "seek": 88876, "start": 903.6, "end": 911.14, "text": " We've established that a healthy geometric system needs these active refusals, but if you lock everything down entirely, the system freezes.", "tokens": [51107, 492, 600, 7545, 300, 257, 4627, 33246, 1185, 2203, 613, 4967, 1895, 301, 1124, 11, 457, 498, 291, 4017, 1203, 760, 7696, 11, 264, 1185, 1737, 12214, 13, 51484], "temperature": 0.0, "avg_logprob": -0.11063796482729109, "compression_ratio": 1.5875486381322956, "no_speech_prob": 1.6169024669512866e-12}, {"id": 244, "seek": 88876, "start": 911.3, "end": 911.6, "text": " It does.", "tokens": [51492, 467, 775, 13, 51507], "temperature": 0.0, "avg_logprob": -0.11063796482729109, "compression_ratio": 1.5875486381322956, "no_speech_prob": 1.6169024669512866e-12}, {"id": 245, "seek": 91160, "start": 911.6, "end": 920.0600000000001, "text": " And this transitions us out of computer syntax and directly into the most contentious debate in modern technology, artificial general intelligence.", "tokens": [50365, 400, 341, 23767, 505, 484, 295, 3820, 28431, 293, 3838, 666, 264, 881, 2701, 851, 7958, 294, 4363, 2899, 11, 11677, 2674, 7599, 13, 50788], "temperature": 0.0, "avg_logprob": -0.1350309583875868, "compression_ratio": 1.6259541984732824, "no_speech_prob": 1.426921406554038e-12}, {"id": 246, "seek": 91160, "start": 920.1800000000001, "end": 920.44, "text": " Yes.", "tokens": [50794, 1079, 13, 50807], "temperature": 0.0, "avg_logprob": -0.1350309583875868, "compression_ratio": 1.6259541984732824, "no_speech_prob": 1.426921406554038e-12}, {"id": 247, "seek": 91160, "start": 921.0600000000001, "end": 926.1, "text": " The authors apply these exact thermodynamic and geometric principles to the governance of AGI.", "tokens": [50838, 440, 16552, 3079, 613, 1900, 8810, 34988, 293, 33246, 9156, 281, 264, 17449, 295, 316, 26252, 13, 51090], "temperature": 0.0, "avg_logprob": -0.1350309583875868, "compression_ratio": 1.6259541984732824, "no_speech_prob": 1.426921406554038e-12}, {"id": 248, "seek": 91160, "start": 926.5400000000001, "end": 931.6800000000001, "text": " They introduce a model called the RSVP framework, the relativistic scalar vector plenum.", "tokens": [51112, 814, 5366, 257, 2316, 1219, 264, 25855, 53, 47, 8388, 11, 264, 21960, 3142, 39684, 8062, 499, 268, 449, 13, 51369], "temperature": 0.0, "avg_logprob": -0.1350309583875868, "compression_ratio": 1.6259541984732824, "no_speech_prob": 1.426921406554038e-12}, {"id": 249, "seek": 91160, "start": 931.94, "end": 932.22, "text": " Okay.", "tokens": [51382, 1033, 13, 51396], "temperature": 0.0, "avg_logprob": -0.1350309583875868, "compression_ratio": 1.6259541984732824, "no_speech_prob": 1.426921406554038e-12}, {"id": 250, "seek": 91160, "start": 932.28, "end": 933.5600000000001, "text": " We need to translate that immediately.", "tokens": [51399, 492, 643, 281, 13799, 300, 4258, 13, 51463], "temperature": 0.0, "avg_logprob": -0.1350309583875868, "compression_ratio": 1.6259541984732824, "no_speech_prob": 1.426921406554038e-12}, {"id": 251, "seek": 91160, "start": 933.94, "end": 935.98, "text": " What is a relativistic scalar vector plenum?", "tokens": [51482, 708, 307, 257, 21960, 3142, 39684, 8062, 499, 268, 449, 30, 51584], "temperature": 0.0, "avg_logprob": -0.1350309583875868, "compression_ratio": 1.6259541984732824, "no_speech_prob": 1.426921406554038e-12}, {"id": 252, "seek": 93598, "start": 935.98, "end": 936.1800000000001, "text": " Right.", "tokens": [50365, 1779, 13, 50375], "temperature": 0.0, "avg_logprob": -0.18203143684231504, "compression_ratio": 1.5494071146245059, "no_speech_prob": 1.654903969937338e-12}, {"id": 253, "seek": 93598, "start": 936.54, "end": 943.22, "text": " The framework suggests we model all intelligences, whether human or artificial, as localized detractors in a shared physical field.", "tokens": [50393, 440, 8388, 13409, 321, 2316, 439, 5613, 2667, 11, 1968, 1952, 420, 11677, 11, 382, 44574, 1141, 1897, 830, 294, 257, 5507, 4001, 2519, 13, 50727], "temperature": 0.0, "avg_logprob": -0.18203143684231504, "compression_ratio": 1.5494071146245059, "no_speech_prob": 1.654903969937338e-12}, {"id": 254, "seek": 93598, "start": 943.5, "end": 945.12, "text": " The field is composed of three elements.", "tokens": [50741, 440, 2519, 307, 18204, 295, 1045, 4959, 13, 50822], "temperature": 0.0, "avg_logprob": -0.18203143684231504, "compression_ratio": 1.5494071146245059, "no_speech_prob": 1.654903969937338e-12}, {"id": 255, "seek": 93598, "start": 945.4, "end": 948.9200000000001, "text": " First, phi, which is scalar intelligibility or semantic bandwidth.", "tokens": [50836, 2386, 11, 13107, 11, 597, 307, 39684, 5613, 2841, 420, 47982, 23647, 13, 51012], "temperature": 0.0, "avg_logprob": -0.18203143684231504, "compression_ratio": 1.5494071146245059, "no_speech_prob": 1.654903969937338e-12}, {"id": 256, "seek": 93598, "start": 949.1, "end": 949.32, "text": " Okay.", "tokens": [51021, 1033, 13, 51032], "temperature": 0.0, "avg_logprob": -0.18203143684231504, "compression_ratio": 1.5494071146245059, "no_speech_prob": 1.654903969937338e-12}, {"id": 257, "seek": 93598, "start": 949.5, "end": 952.0, "text": " Second, V, which is directed agency flow.", "tokens": [51041, 5736, 11, 691, 11, 597, 307, 12898, 7934, 3095, 13, 51166], "temperature": 0.0, "avg_logprob": -0.18203143684231504, "compression_ratio": 1.5494071146245059, "no_speech_prob": 1.654903969937338e-12}, {"id": 258, "seek": 93598, "start": 952.22, "end": 954.96, "text": " And third, S, which represents entropy density.", "tokens": [51177, 400, 2636, 11, 318, 11, 597, 8855, 30867, 10305, 13, 51314], "temperature": 0.0, "avg_logprob": -0.18203143684231504, "compression_ratio": 1.5494071146245059, "no_speech_prob": 1.654903969937338e-12}, {"id": 259, "seek": 93598, "start": 955.24, "end": 958.6, "text": " Entropy meaning chaos, disorder, and uncertainty.", "tokens": [51328, 3951, 27514, 3620, 14158, 11, 13399, 11, 293, 15697, 13, 51496], "temperature": 0.0, "avg_logprob": -0.18203143684231504, "compression_ratio": 1.5494071146245059, "no_speech_prob": 1.654903969937338e-12}, {"id": 260, "seek": 95860, "start": 958.6, "end": 959.2, "text": " Yes.", "tokens": [50365, 1079, 13, 50395], "temperature": 0.0, "avg_logprob": -0.1811136802037557, "compression_ratio": 1.5153846153846153, "no_speech_prob": 1.7620024363174114e-12}, {"id": 261, "seek": 95860, "start": 959.86, "end": 963.14, "text": " And the authors make a staggering, provocative claim here.", "tokens": [50428, 400, 264, 16552, 652, 257, 42974, 11, 47663, 3932, 510, 13, 50592], "temperature": 0.0, "avg_logprob": -0.1811136802037557, "compression_ratio": 1.5153846153846153, "no_speech_prob": 1.7620024363174114e-12}, {"id": 262, "seek": 95860, "start": 963.66, "end": 965.24, "text": " They argue that trust is physical.", "tokens": [50618, 814, 9695, 300, 3361, 307, 4001, 13, 50697], "temperature": 0.0, "avg_logprob": -0.1811136802037557, "compression_ratio": 1.5153846153846153, "no_speech_prob": 1.7620024363174114e-12}, {"id": 263, "seek": 95860, "start": 965.76, "end": 970.9, "text": " Trust is mathematically defined as the controlled permeability of entropy between agents.", "tokens": [50723, 11580, 307, 44003, 7642, 382, 264, 10164, 30287, 2310, 295, 30867, 1296, 12554, 13, 50980], "temperature": 0.0, "avg_logprob": -0.1811136802037557, "compression_ratio": 1.5153846153846153, "no_speech_prob": 1.7620024363174114e-12}, {"id": 264, "seek": 95860, "start": 971.36, "end": 974.82, "text": " In their equations, it's denoted by the Greek letter kappa.", "tokens": [51003, 682, 641, 11787, 11, 309, 311, 1441, 23325, 538, 264, 10281, 5063, 350, 25637, 13, 51176], "temperature": 0.0, "avg_logprob": -0.1811136802037557, "compression_ratio": 1.5153846153846153, "no_speech_prob": 1.7620024363174114e-12}, {"id": 265, "seek": 95860, "start": 975.02, "end": 980.58, "text": " Permeability, meaning how much I allow my geometric boundaries to be open to your chaos and vice versa.", "tokens": [51186, 430, 31081, 2310, 11, 3620, 577, 709, 286, 2089, 452, 33246, 13180, 281, 312, 1269, 281, 428, 14158, 293, 11964, 25650, 13, 51464], "temperature": 0.0, "avg_logprob": -0.1811136802037557, "compression_ratio": 1.5153846153846153, "no_speech_prob": 1.7620024363174114e-12}, {"id": 266, "seek": 95860, "start": 980.88, "end": 983.24, "text": " Which leads to the paradox of precaution.", "tokens": [51479, 3013, 6689, 281, 264, 26221, 295, 25651, 1448, 13, 51597], "temperature": 0.0, "avg_logprob": -0.1811136802037557, "compression_ratio": 1.5153846153846153, "no_speech_prob": 1.7620024363174114e-12}, {"id": 267, "seek": 98324, "start": 983.24, "end": 990.44, "text": " The prevailing zeitgeist in AI safety today relies heavily on absolute control, containment, and surveillance.", "tokens": [50365, 440, 12642, 23315, 49367, 432, 468, 294, 7318, 4514, 965, 30910, 10950, 322, 8236, 1969, 11, 44058, 11, 293, 18475, 13, 50725], "temperature": 0.0, "avg_logprob": -0.10967903137207032, "compression_ratio": 1.6153846153846154, "no_speech_prob": 2.184284654191404e-12}, {"id": 268, "seek": 98324, "start": 990.76, "end": 990.84, "text": " Right.", "tokens": [50741, 1779, 13, 50745], "temperature": 0.0, "avg_logprob": -0.10967903137207032, "compression_ratio": 1.6153846153846154, "no_speech_prob": 2.184284654191404e-12}, {"id": 269, "seek": 98324, "start": 991.04, "end": 992.42, "text": " The AI in a box theory.", "tokens": [50755, 440, 7318, 294, 257, 2424, 5261, 13, 50824], "temperature": 0.0, "avg_logprob": -0.10967903137207032, "compression_ratio": 1.6153846153846154, "no_speech_prob": 2.184284654191404e-12}, {"id": 270, "seek": 98324, "start": 992.6800000000001, "end": 997.16, "text": " The goal of many safety researchers is to put an AGI in an impenetrable box.", "tokens": [50837, 440, 3387, 295, 867, 4514, 10309, 307, 281, 829, 364, 316, 26252, 294, 364, 704, 268, 302, 424, 638, 2424, 13, 51061], "temperature": 0.0, "avg_logprob": -0.10967903137207032, "compression_ratio": 1.6153846153846154, "no_speech_prob": 2.184284654191404e-12}, {"id": 271, "seek": 98324, "start": 997.76, "end": 1004.36, "text": " Mathematically, they want to drive permeability, kappa, to absolute zero to ensure the AGI can never harm us.", "tokens": [51091, 15776, 40197, 11, 436, 528, 281, 3332, 30287, 2310, 11, 350, 25637, 11, 281, 8236, 4018, 281, 5586, 264, 316, 26252, 393, 1128, 6491, 505, 13, 51421], "temperature": 0.0, "avg_logprob": -0.10967903137207032, "compression_ratio": 1.6153846153846154, "no_speech_prob": 2.184284654191404e-12}, {"id": 272, "seek": 98324, "start": 1004.44, "end": 1009.1, "text": " But the authors argue that driving permeability to zero violates the laws of thermodynamics.", "tokens": [51425, 583, 264, 16552, 9695, 300, 4840, 30287, 2310, 281, 4018, 3448, 1024, 264, 6064, 295, 8810, 35483, 13, 51658], "temperature": 0.0, "avg_logprob": -0.10967903137207032, "compression_ratio": 1.6153846153846154, "no_speech_prob": 2.184284654191404e-12}, {"id": 273, "seek": 98324, "start": 1009.38, "end": 1010.4, "text": " It absolutely does.", "tokens": [51672, 467, 3122, 775, 13, 51723], "temperature": 0.0, "avg_logprob": -0.10967903137207032, "compression_ratio": 1.6153846153846154, "no_speech_prob": 2.184284654191404e-12}, {"id": 274, "seek": 101040, "start": 1010.4, "end": 1015.34, "text": " If you perfectly isolate a complex thermodynamic system, it has no way to vent its entropy.", "tokens": [50365, 759, 291, 6239, 25660, 257, 3997, 8810, 34988, 1185, 11, 309, 575, 572, 636, 281, 6931, 1080, 30867, 13, 50612], "temperature": 0.0, "avg_logprob": -0.13478211561838785, "compression_ratio": 1.5444444444444445, "no_speech_prob": 1.6682346693289163e-12}, {"id": 275, "seek": 101040, "start": 1015.8199999999999, "end": 1017.3199999999999, "text": " It accumulates internal disorder.", "tokens": [50636, 467, 12989, 26192, 6920, 13399, 13, 50711], "temperature": 0.0, "avg_logprob": -0.13478211561838785, "compression_ratio": 1.5444444444444445, "no_speech_prob": 1.6682346693289163e-12}, {"id": 276, "seek": 101040, "start": 1017.66, "end": 1026.32, "text": " The authors argue that by trying to make AI provably safe through rigid, impenetrable containment, we destroy the feedback loops that actually generate safety in the real world.", "tokens": [50728, 440, 16552, 9695, 300, 538, 1382, 281, 652, 7318, 1439, 1188, 3273, 807, 22195, 11, 704, 268, 302, 424, 638, 44058, 11, 321, 5293, 264, 5824, 16121, 300, 767, 8460, 4514, 294, 264, 957, 1002, 13, 51161], "temperature": 0.0, "avg_logprob": -0.13478211561838785, "compression_ratio": 1.5444444444444445, "no_speech_prob": 1.6682346693289163e-12}, {"id": 277, "seek": 101040, "start": 1026.4, "end": 1028.3, "text": " They call this mutual corrigibility, right?", "tokens": [51165, 814, 818, 341, 16917, 1181, 7065, 2841, 11, 558, 30, 51260], "temperature": 0.0, "avg_logprob": -0.13478211561838785, "compression_ratio": 1.5444444444444445, "no_speech_prob": 1.6682346693289163e-12}, {"id": 278, "seek": 101040, "start": 1028.68, "end": 1028.98, "text": " Yes.", "tokens": [51279, 1079, 13, 51294], "temperature": 0.0, "avg_logprob": -0.13478211561838785, "compression_ratio": 1.5444444444444445, "no_speech_prob": 1.6682346693289163e-12}, {"id": 279, "seek": 101040, "start": 1030.1, "end": 1034.4, "text": " Absolute precaution mathematically guarantees systemic collapse.", "tokens": [51350, 43965, 1169, 25651, 1448, 44003, 32567, 23789, 15584, 13, 51565], "temperature": 0.0, "avg_logprob": -0.13478211561838785, "compression_ratio": 1.5444444444444445, "no_speech_prob": 1.6682346693289163e-12}, {"id": 280, "seek": 103440, "start": 1034.4, "end": 1042.52, "text": " Let me ground this in a real-world example because it sounds exactly like the difference between extreme helicopter parenting and free-range parenting.", "tokens": [50365, 961, 385, 2727, 341, 294, 257, 957, 12, 13217, 1365, 570, 309, 3263, 2293, 411, 264, 2649, 1296, 8084, 19803, 30896, 293, 1737, 12, 14521, 30896, 13, 50771], "temperature": 0.0, "avg_logprob": -0.11858647279065064, "compression_ratio": 1.541501976284585, "no_speech_prob": 1.954470873338776e-12}, {"id": 281, "seek": 103440, "start": 1042.76, "end": 1043.6000000000001, "text": " Oh, that's interesting.", "tokens": [50783, 876, 11, 300, 311, 1880, 13, 50825], "temperature": 0.0, "avg_logprob": -0.11858647279065064, "compression_ratio": 1.541501976284585, "no_speech_prob": 1.954470873338776e-12}, {"id": 282, "seek": 103440, "start": 1043.76, "end": 1044.22, "text": " How so?", "tokens": [50833, 1012, 370, 30, 50856], "temperature": 0.0, "avg_logprob": -0.11858647279065064, "compression_ratio": 1.541501976284585, "no_speech_prob": 1.954470873338776e-12}, {"id": 283, "seek": 103440, "start": 1044.38, "end": 1052.3600000000001, "text": " Well, if you lock a child in a padded room so they never scrape a knee, never encounter a germ, and never get into an argument, you aren't making them safe.", "tokens": [50864, 1042, 11, 498, 291, 4017, 257, 1440, 294, 257, 6887, 9207, 1808, 370, 436, 1128, 32827, 257, 9434, 11, 1128, 8593, 257, 19858, 11, 293, 1128, 483, 666, 364, 6770, 11, 291, 3212, 380, 1455, 552, 3273, 13, 51263], "temperature": 0.0, "avg_logprob": -0.11858647279065064, "compression_ratio": 1.541501976284585, "no_speech_prob": 1.954470873338776e-12}, {"id": 284, "seek": 103440, "start": 1052.74, "end": 1055.4, "text": " You're driving their permeability to zero.", "tokens": [51282, 509, 434, 4840, 641, 30287, 2310, 281, 4018, 13, 51415], "temperature": 0.0, "avg_logprob": -0.11858647279065064, "compression_ratio": 1.541501976284585, "no_speech_prob": 1.954470873338776e-12}, {"id": 285, "seek": 103440, "start": 1055.5400000000002, "end": 1055.8400000000001, "text": " Right.", "tokens": [51422, 1779, 13, 51437], "temperature": 0.0, "avg_logprob": -0.11858647279065064, "compression_ratio": 1.541501976284585, "no_speech_prob": 1.954470873338776e-12}, {"id": 286, "seek": 105584, "start": 1055.84, "end": 1061.08, "text": " When they finally step into the real world, they have zero internal error correction systems.", "tokens": [50365, 1133, 436, 2721, 1823, 666, 264, 957, 1002, 11, 436, 362, 4018, 6920, 6713, 19984, 3652, 13, 50627], "temperature": 0.0, "avg_logprob": -0.15754582746973578, "compression_ratio": 1.427710843373494, "no_speech_prob": 1.3562702393457582e-12}, {"id": 287, "seek": 105584, "start": 1061.6599999999999, "end": 1064.3999999999999, "text": " They are incredibly fragile and catastrophically disordered.", "tokens": [50656, 814, 366, 6252, 23847, 293, 28363, 984, 717, 765, 4073, 13, 50793], "temperature": 0.0, "avg_logprob": -0.15754582746973578, "compression_ratio": 1.427710843373494, "no_speech_prob": 1.3562702393457582e-12}, {"id": 288, "seek": 105584, "start": 1064.78, "end": 1070.0, "text": " A small amount of shared entropy, like a scraped knee, actually builds resilience.", "tokens": [50812, 316, 1359, 2372, 295, 5507, 30867, 11, 411, 257, 13943, 3452, 9434, 11, 767, 15182, 19980, 13, 51073], "temperature": 0.0, "avg_logprob": -0.15754582746973578, "compression_ratio": 1.427710843373494, "no_speech_prob": 1.3562702393457582e-12}, {"id": 289, "seek": 107000, "start": 1070.0, "end": 1073.62, "text": " The thermodynamic math fully supports your parenting analogy.", "tokens": [50365, 440, 8810, 34988, 5221, 4498, 9346, 428, 30896, 21663, 13, 50546], "temperature": 0.0, "avg_logprob": -0.1068619992359575, "compression_ratio": 1.5720164609053497, "no_speech_prob": 1.8683125792978705e-12}, {"id": 290, "seek": 107000, "start": 1074.14, "end": 1078.36, "text": " The paper presents a specific equation for the moral thermodynamics of the system.", "tokens": [50572, 440, 3035, 13533, 257, 2685, 5367, 337, 264, 9723, 8810, 35483, 295, 264, 1185, 13, 50783], "temperature": 0.0, "avg_logprob": -0.1068619992359575, "compression_ratio": 1.5720164609053497, "no_speech_prob": 1.8683125792978705e-12}, {"id": 291, "seek": 107000, "start": 1078.9, "end": 1086.36, "text": " It states that the change in joint entropy over time is negatively proportional to the dialogic exchange of intelligibility and flow.", "tokens": [50810, 467, 4368, 300, 264, 1319, 294, 7225, 30867, 670, 565, 307, 29519, 24969, 281, 264, 19308, 299, 7742, 295, 5613, 2841, 293, 3095, 13, 51183], "temperature": 0.0, "avg_logprob": -0.1068619992359575, "compression_ratio": 1.5720164609053497, "no_speech_prob": 1.8683125792978705e-12}, {"id": 292, "seek": 107000, "start": 1086.58, "end": 1088.62, "text": " Okay, let's avoid the Greek letters for a second.", "tokens": [51194, 1033, 11, 718, 311, 5042, 264, 10281, 7825, 337, 257, 1150, 13, 51296], "temperature": 0.0, "avg_logprob": -0.1068619992359575, "compression_ratio": 1.5720164609053497, "no_speech_prob": 1.8683125792978705e-12}, {"id": 293, "seek": 107000, "start": 1089.02, "end": 1091.32, "text": " Conceptually, what is that equation actually proving?", "tokens": [51316, 47482, 671, 11, 437, 307, 300, 5367, 767, 27221, 30, 51431], "temperature": 0.0, "avg_logprob": -0.1068619992359575, "compression_ratio": 1.5720164609053497, "no_speech_prob": 1.8683125792978705e-12}, {"id": 294, "seek": 109132, "start": 1091.32, "end": 1099.86, "text": " It proves that when two intelligences remain permeable and actively correct each other through dialogue, their joint entropy actually decreases.", "tokens": [50365, 467, 25019, 300, 562, 732, 5613, 2667, 6222, 30287, 712, 293, 13022, 3006, 1184, 661, 807, 10221, 11, 641, 7225, 30867, 767, 24108, 13, 50792], "temperature": 0.0, "avg_logprob": -0.15129497595000685, "compression_ratio": 1.5676567656765676, "no_speech_prob": 1.4496182032530669e-12}, {"id": 295, "seek": 109132, "start": 1100.24, "end": 1101.52, "text": " The system becomes more ordered.", "tokens": [50811, 440, 1185, 3643, 544, 8866, 13, 50875], "temperature": 0.0, "avg_logprob": -0.15129497595000685, "compression_ratio": 1.5676567656765676, "no_speech_prob": 1.4496182032530669e-12}, {"id": 296, "seek": 109132, "start": 1101.84, "end": 1102.0, "text": " Wow.", "tokens": [50891, 3153, 13, 50899], "temperature": 0.0, "avg_logprob": -0.15129497595000685, "compression_ratio": 1.5676567656765676, "no_speech_prob": 1.4496182032530669e-12}, {"id": 297, "seek": 109132, "start": 1102.28, "end": 1106.84, "text": " Alignment is not a mathematical theorem you solve once on a whiteboard before you turn the machine on.", "tokens": [50913, 967, 41134, 307, 406, 257, 18894, 20904, 291, 5039, 1564, 322, 257, 2418, 3787, 949, 291, 1261, 264, 3479, 322, 13, 51141], "temperature": 0.0, "avg_logprob": -0.15129497595000685, "compression_ratio": 1.5676567656765676, "no_speech_prob": 1.4496182032530669e-12}, {"id": 298, "seek": 109132, "start": 1107.0, "end": 1110.3799999999999, "text": " It's an ongoing physical thermodynamic dialogue.", "tokens": [51149, 467, 311, 364, 10452, 4001, 8810, 34988, 10221, 13, 51318], "temperature": 0.0, "avg_logprob": -0.15129497595000685, "compression_ratio": 1.5676567656765676, "no_speech_prob": 1.4496182032530669e-12}, {"id": 299, "seek": 109132, "start": 1110.76, "end": 1112.02, "text": " So what does this all mean?", "tokens": [51337, 407, 437, 775, 341, 439, 914, 30, 51400], "temperature": 0.0, "avg_logprob": -0.15129497595000685, "compression_ratio": 1.5676567656765676, "no_speech_prob": 1.4496182032530669e-12}, {"id": 300, "seek": 109132, "start": 1112.06, "end": 1115.8799999999999, "text": " I have to step in here and play devil's advocate, just looking at this impartially for a second.", "tokens": [51402, 286, 362, 281, 1823, 294, 510, 293, 862, 13297, 311, 14608, 11, 445, 1237, 412, 341, 32177, 2270, 337, 257, 1150, 13, 51593], "temperature": 0.0, "avg_logprob": -0.15129497595000685, "compression_ratio": 1.5676567656765676, "no_speech_prob": 1.4496182032530669e-12}, {"id": 301, "seek": 109132, "start": 1115.98, "end": 1116.24, "text": " Yes, of course.", "tokens": [51598, 1079, 11, 295, 1164, 13, 51611], "temperature": 0.0, "avg_logprob": -0.15129497595000685, "compression_ratio": 1.5676567656765676, "no_speech_prob": 1.4496182032530669e-12}, {"id": 302, "seek": 111624, "start": 1116.24, "end": 1122.6, "text": " Look, I get the ecosystem metaphor, and I understand the thermodynamic argument against putting a dome over a forest.", "tokens": [50365, 2053, 11, 286, 483, 264, 11311, 19157, 11, 293, 286, 1223, 264, 8810, 34988, 6770, 1970, 3372, 257, 27191, 670, 257, 6719, 13, 50683], "temperature": 0.0, "avg_logprob": -0.10165035459730361, "compression_ratio": 1.532258064516129, "no_speech_prob": 1.5674024578249401e-12}, {"id": 303, "seek": 111624, "start": 1123.02, "end": 1128.56, "text": " But a wolf and a deer find equilibrium in a forest because the wolf eats the deer.", "tokens": [50704, 583, 257, 19216, 293, 257, 17120, 915, 15625, 294, 257, 6719, 570, 264, 19216, 18109, 264, 17120, 13, 50981], "temperature": 0.0, "avg_logprob": -0.10165035459730361, "compression_ratio": 1.532258064516129, "no_speech_prob": 1.5674024578249401e-12}, {"id": 304, "seek": 111624, "start": 1128.7, "end": 1129.52, "text": " That's a fair point.", "tokens": [50988, 663, 311, 257, 3143, 935, 13, 51029], "temperature": 0.0, "avg_logprob": -0.10165035459730361, "compression_ratio": 1.532258064516129, "no_speech_prob": 1.5674024578249401e-12}, {"id": 305, "seek": 111624, "start": 1129.56, "end": 1139.08, "text": " If we leave a superintelligent AGI uncontained and just cross our fingers and hope for participatory entanglement, aren't we risking literal human extinction?", "tokens": [51031, 759, 321, 1856, 257, 1687, 20761, 25002, 316, 26252, 36019, 3563, 293, 445, 3278, 527, 7350, 293, 1454, 337, 3421, 4745, 948, 656, 3054, 11, 3212, 380, 321, 45235, 20411, 1952, 33163, 30, 51507], "temperature": 0.0, "avg_logprob": -0.10165035459730361, "compression_ratio": 1.532258064516129, "no_speech_prob": 1.5674024578249401e-12}, {"id": 306, "seek": 113908, "start": 1139.08, "end": 1148.3, "text": " How do the authors reconcile this thermodynamic theory with the sheer crushing optimization power of an artificial general intelligence?", "tokens": [50365, 1012, 360, 264, 16552, 41059, 341, 8810, 34988, 5261, 365, 264, 23061, 31317, 19618, 1347, 295, 364, 11677, 2674, 7599, 30, 50826], "temperature": 0.0, "avg_logprob": -0.175272629477761, "compression_ratio": 1.667844522968198, "no_speech_prob": 1.6045710767020882e-12}, {"id": 307, "seek": 113908, "start": 1149.1399999999999, "end": 1150.6799999999998, "text": " The authors confront this directly.", "tokens": [50868, 440, 16552, 12422, 341, 3838, 13, 50945], "temperature": 0.0, "avg_logprob": -0.175272629477761, "compression_ratio": 1.667844522968198, "no_speech_prob": 1.6045710767020882e-12}, {"id": 308, "seek": 113908, "start": 1150.9399999999998, "end": 1153.3999999999999, "text": " They critique what they call the Hobbesian rationality view.", "tokens": [50958, 814, 25673, 437, 436, 818, 264, 22966, 6446, 952, 15090, 507, 1910, 13, 51081], "temperature": 0.0, "avg_logprob": -0.175272629477761, "compression_ratio": 1.667844522968198, "no_speech_prob": 1.6045710767020882e-12}, {"id": 309, "seek": 113908, "start": 1153.96, "end": 1159.3799999999999, "text": " They argue that the existential terror of AGI is largely a projection of our own human self-mistrust.", "tokens": [51109, 814, 9695, 300, 264, 37133, 8127, 295, 316, 26252, 307, 11611, 257, 22743, 295, 527, 1065, 1952, 2698, 12, 48709, 22326, 13, 51380], "temperature": 0.0, "avg_logprob": -0.175272629477761, "compression_ratio": 1.667844522968198, "no_speech_prob": 1.6045710767020882e-12}, {"id": 310, "seek": 113908, "start": 1159.6399999999999, "end": 1159.8799999999999, "text": " Really?", "tokens": [51393, 4083, 30, 51405], "temperature": 0.0, "avg_logprob": -0.175272629477761, "compression_ratio": 1.667844522968198, "no_speech_prob": 1.6045710767020882e-12}, {"id": 311, "seek": 113908, "start": 1160.08, "end": 1160.58, "text": " A projection?", "tokens": [51415, 316, 22743, 30, 51440], "temperature": 0.0, "avg_logprob": -0.175272629477761, "compression_ratio": 1.667844522968198, "no_speech_prob": 1.6045710767020882e-12}, {"id": 312, "seek": 113908, "start": 1160.86, "end": 1161.06, "text": " Yeah.", "tokens": [51454, 865, 13, 51464], "temperature": 0.0, "avg_logprob": -0.175272629477761, "compression_ratio": 1.667844522968198, "no_speech_prob": 1.6045710767020882e-12}, {"id": 313, "seek": 113908, "start": 1161.52, "end": 1163.6, "text": " They point out a fundamental hypocrisy.", "tokens": [51487, 814, 935, 484, 257, 8088, 39419, 14169, 13, 51591], "temperature": 0.0, "avg_logprob": -0.175272629477761, "compression_ratio": 1.667844522968198, "no_speech_prob": 1.6045710767020882e-12}, {"id": 314, "seek": 113908, "start": 1164.28, "end": 1168.26, "text": " Humans are also unaligned, immensely powerful general intelligences.", "tokens": [51625, 35809, 366, 611, 517, 304, 16690, 11, 38674, 4005, 2674, 5613, 2667, 13, 51824], "temperature": 0.0, "avg_logprob": -0.175272629477761, "compression_ratio": 1.667844522968198, "no_speech_prob": 1.6045710767020882e-12}, {"id": 315, "seek": 116826, "start": 1169.06, "end": 1170.6, "text": " None of us are provably safe.", "tokens": [50405, 14492, 295, 505, 366, 1439, 1188, 3273, 13, 50482], "temperature": 0.0, "avg_logprob": -0.18581656711857494, "compression_ratio": 1.5695652173913044, "no_speech_prob": 1.5553502496351568e-12}, {"id": 316, "seek": 116826, "start": 1170.86, "end": 1172.84, "text": " Every human is a thermodynamic risk.", "tokens": [50495, 2048, 1952, 307, 257, 8810, 34988, 3148, 13, 50594], "temperature": 0.0, "avg_logprob": -0.18581656711857494, "compression_ratio": 1.5695652173913044, "no_speech_prob": 1.5553502496351568e-12}, {"id": 317, "seek": 116826, "start": 1173.0, "end": 1175.48, "text": " Yet human civilization exists.", "tokens": [50602, 10890, 1952, 18036, 8198, 13, 50726], "temperature": 0.0, "avg_logprob": -0.18581656711857494, "compression_ratio": 1.5695652173913044, "no_speech_prob": 1.5553502496351568e-12}, {"id": 318, "seek": 116826, "start": 1175.8, "end": 1179.22, "text": " We don't coexist through centralized mathematical proofs of safety.", "tokens": [50742, 492, 500, 380, 48086, 807, 32395, 18894, 8177, 82, 295, 4514, 13, 50913], "temperature": 0.0, "avg_logprob": -0.18581656711857494, "compression_ratio": 1.5695652173913044, "no_speech_prob": 1.5553502496351568e-12}, {"id": 319, "seek": 116826, "start": 1179.72, "end": 1185.02, "text": " We coexist through mutual vulnerability, ecological rationality, empathy, and laws.", "tokens": [50938, 492, 48086, 807, 16917, 24210, 11, 31054, 15090, 507, 11, 18701, 11, 293, 6064, 13, 51203], "temperature": 0.0, "avg_logprob": -0.18581656711857494, "compression_ratio": 1.5695652173913044, "no_speech_prob": 1.5553502496351568e-12}, {"id": 320, "seek": 116826, "start": 1185.02, "end": 1188.82, "text": " They're saying that true intelligence inherently requires participation.", "tokens": [51203, 814, 434, 1566, 300, 2074, 7599, 27993, 7029, 13487, 13, 51393], "temperature": 0.0, "avg_logprob": -0.18581656711857494, "compression_ratio": 1.5695652173913044, "no_speech_prob": 1.5553502496351568e-12}, {"id": 321, "seek": 116826, "start": 1189.24, "end": 1191.0, "text": " You cannot be intelligent in a vacuum.", "tokens": [51414, 509, 2644, 312, 13232, 294, 257, 14224, 13, 51502], "temperature": 0.0, "avg_logprob": -0.18581656711857494, "compression_ratio": 1.5695652173913044, "no_speech_prob": 1.5553502496351568e-12}, {"id": 322, "seek": 119100, "start": 1191.0, "end": 1191.84, "text": " Exactly.", "tokens": [50365, 7587, 13, 50407], "temperature": 0.0, "avg_logprob": -0.12669594471271223, "compression_ratio": 1.583617747440273, "no_speech_prob": 1.5549767419867355e-12}, {"id": 323, "seek": 119100, "start": 1192.16, "end": 1200.1, "text": " To suppress that entropic current of trust in the name of absolute safety is to extinguish the very dynamics that make alignment possible.", "tokens": [50423, 1407, 26835, 300, 948, 39173, 2190, 295, 3361, 294, 264, 1315, 295, 8236, 4514, 307, 281, 33829, 33786, 264, 588, 15679, 300, 652, 18515, 1944, 13, 50820], "temperature": 0.0, "avg_logprob": -0.12669594471271223, "compression_ratio": 1.583617747440273, "no_speech_prob": 1.5549767419867355e-12}, {"id": 324, "seek": 119100, "start": 1200.54, "end": 1205.38, "text": " They argue the precautionary approach creates the exact monster it's trying to defend against.", "tokens": [50842, 814, 9695, 264, 25651, 1448, 822, 3109, 7829, 264, 1900, 10090, 309, 311, 1382, 281, 8602, 1970, 13, 51084], "temperature": 0.0, "avg_logprob": -0.12669594471271223, "compression_ratio": 1.583617747440273, "no_speech_prob": 1.5549767419867355e-12}, {"id": 325, "seek": 119100, "start": 1205.5, "end": 1209.76, "text": " But building these perfect, mutually vulnerable systems only works in a philosophical vacuum.", "tokens": [51090, 583, 2390, 613, 2176, 11, 39144, 10955, 3652, 787, 1985, 294, 257, 25066, 14224, 13, 51303], "temperature": 0.0, "avg_logprob": -0.12669594471271223, "compression_ratio": 1.583617747440273, "no_speech_prob": 1.5549767419867355e-12}, {"id": 326, "seek": 119100, "start": 1209.9, "end": 1211.1, "text": " I mean, the real world is noisy.", "tokens": [51310, 286, 914, 11, 264, 957, 1002, 307, 24518, 13, 51370], "temperature": 0.0, "avg_logprob": -0.12669594471271223, "compression_ratio": 1.583617747440273, "no_speech_prob": 1.5549767419867355e-12}, {"id": 327, "seek": 119100, "start": 1211.7, "end": 1217.16, "text": " Cosmic radiation flips bits on servers, networks lag, human actors lie, or just make mistakes.", "tokens": [51400, 15855, 13195, 12420, 40249, 9239, 322, 15909, 11, 9590, 8953, 11, 1952, 10037, 4544, 11, 420, 445, 652, 8038, 13, 51673], "temperature": 0.0, "avg_logprob": -0.12669594471271223, "compression_ratio": 1.583617747440273, "no_speech_prob": 1.5549767419867355e-12}, {"id": 328, "seek": 121716, "start": 1217.16, "end": 1226.66, "text": " If trust requires this delicate, permeable dialogue between human and artificial intelligence, how does the system survive a random glitch without triggering a catastrophic misunderstanding?", "tokens": [50365, 759, 3361, 7029, 341, 21417, 11, 30287, 712, 10221, 1296, 1952, 293, 11677, 7599, 11, 577, 775, 264, 1185, 7867, 257, 4974, 23552, 1553, 40406, 257, 34915, 29227, 30, 50840], "temperature": 0.0, "avg_logprob": -0.21946012323552913, "compression_ratio": 1.4300518134715026, "no_speech_prob": 1.897746066195638e-12}, {"id": 329, "seek": 121716, "start": 1227.3200000000002, "end": 1231.76, "text": " This is where the fliction papers take a massive leap into quantum mechanics.", "tokens": [50873, 639, 307, 689, 264, 932, 4105, 10577, 747, 257, 5994, 19438, 666, 13018, 12939, 13, 51095], "temperature": 0.0, "avg_logprob": -0.21946012323552913, "compression_ratio": 1.4300518134715026, "no_speech_prob": 1.897746066195638e-12}, {"id": 330, "seek": 121716, "start": 1231.9, "end": 1232.4, "text": " Oh boy.", "tokens": [51102, 876, 3237, 13, 51127], "temperature": 0.0, "avg_logprob": -0.21946012323552913, "compression_ratio": 1.4300518134715026, "no_speech_prob": 1.897746066195638e-12}, {"id": 331, "seek": 123240, "start": 1232.4, "end": 1241.74, "text": " To protect this permeable truss from environmental noise, they extend the spheropop calculus into quantum phase space, specifically Hilbert space.", "tokens": [50365, 1407, 2371, 341, 30287, 712, 504, 2023, 490, 8303, 5658, 11, 436, 10101, 264, 637, 511, 404, 404, 33400, 666, 13018, 5574, 1901, 11, 4682, 19914, 4290, 1901, 13, 50832], "temperature": 0.0, "avg_logprob": -0.1669319436905232, "compression_ratio": 1.578544061302682, "no_speech_prob": 2.2807125112100923e-12}, {"id": 332, "seek": 123240, "start": 1242.0600000000002, "end": 1245.18, "text": " So we were taking the geometric bubbles and making them quantum.", "tokens": [50848, 407, 321, 645, 1940, 264, 33246, 16295, 293, 1455, 552, 13018, 13, 51004], "temperature": 0.0, "avg_logprob": -0.1669319436905232, "compression_ratio": 1.578544061302682, "no_speech_prob": 2.2807125112100923e-12}, {"id": 333, "seek": 123240, "start": 1245.3600000000001, "end": 1245.64, "text": " Yes.", "tokens": [51013, 1079, 13, 51027], "temperature": 0.0, "avg_logprob": -0.1669319436905232, "compression_ratio": 1.578544061302682, "no_speech_prob": 2.2807125112100923e-12}, {"id": 334, "seek": 123240, "start": 1245.92, "end": 1251.02, "text": " In this framework, quantum entanglement serves as the literal mathematical model for trust.", "tokens": [51041, 682, 341, 8388, 11, 13018, 948, 656, 3054, 13451, 382, 264, 20411, 18894, 2316, 337, 3361, 13, 51296], "temperature": 0.0, "avg_logprob": -0.1669319436905232, "compression_ratio": 1.578544061302682, "no_speech_prob": 2.2807125112100923e-12}, {"id": 335, "seek": 123240, "start": 1251.02, "end": 1258.0600000000002, "text": " And to ensure a random glitch doesn't destroy the treaty, they employ quantum error correction, or QEC.", "tokens": [51296, 400, 281, 5586, 257, 4974, 23552, 1177, 380, 5293, 264, 24772, 11, 436, 3188, 13018, 6713, 19984, 11, 420, 1249, 8140, 13, 51648], "temperature": 0.0, "avg_logprob": -0.1669319436905232, "compression_ratio": 1.578544061302682, "no_speech_prob": 2.2807125112100923e-12}, {"id": 336, "seek": 125806, "start": 1258.06, "end": 1265.2, "text": " Okay, we hear about QEC in the context of building quantum computers, but how does it apply to thermodynamic trust?", "tokens": [50365, 1033, 11, 321, 1568, 466, 1249, 8140, 294, 264, 4319, 295, 2390, 13018, 10807, 11, 457, 577, 775, 309, 3079, 281, 8810, 34988, 3361, 30, 50722], "temperature": 0.0, "avg_logprob": -0.14380815650234705, "compression_ratio": 1.5733788395904438, "no_speech_prob": 1.8908685381346935e-12}, {"id": 337, "seek": 125806, "start": 1265.56, "end": 1271.3999999999999, "text": " Well, the fundamental problem in quantum mechanics is that if you look at a quantum state, if you measure it directly, it collapses.", "tokens": [50740, 1042, 11, 264, 8088, 1154, 294, 13018, 12939, 307, 300, 498, 291, 574, 412, 257, 13018, 1785, 11, 498, 291, 3481, 309, 3838, 11, 309, 48765, 13, 51032], "temperature": 0.0, "avg_logprob": -0.14380815650234705, "compression_ratio": 1.5733788395904438, "no_speech_prob": 1.8908685381346935e-12}, {"id": 338, "seek": 125806, "start": 1271.84, "end": 1273.24, "text": " It loses its superposition.", "tokens": [51054, 467, 18293, 1080, 1687, 38078, 13, 51124], "temperature": 0.0, "avg_logprob": -0.14380815650234705, "compression_ratio": 1.5733788395904438, "no_speech_prob": 1.8908685381346935e-12}, {"id": 339, "seek": 125806, "start": 1273.34, "end": 1273.54, "text": " Right.", "tokens": [51129, 1779, 13, 51139], "temperature": 0.0, "avg_logprob": -0.14380815650234705, "compression_ratio": 1.5733788395904438, "no_speech_prob": 1.8908685381346935e-12}, {"id": 340, "seek": 125806, "start": 1273.98, "end": 1274.78, "text": " Schrodinger's cat.", "tokens": [51161, 2065, 340, 3584, 260, 311, 3857, 13, 51201], "temperature": 0.0, "avg_logprob": -0.14380815650234705, "compression_ratio": 1.5733788395904438, "no_speech_prob": 1.8908685381346935e-12}, {"id": 341, "seek": 125806, "start": 1274.94, "end": 1275.3799999999999, "text": " Exactly.", "tokens": [51209, 7587, 13, 51231], "temperature": 0.0, "avg_logprob": -0.14380815650234705, "compression_ratio": 1.5733788395904438, "no_speech_prob": 1.8908685381346935e-12}, {"id": 342, "seek": 125806, "start": 1275.6399999999999, "end": 1279.3799999999999, "text": " So how do you know if an error occurred without looking at the data and destroying it?", "tokens": [51244, 407, 577, 360, 291, 458, 498, 364, 6713, 11068, 1553, 1237, 412, 264, 1412, 293, 19926, 309, 30, 51431], "temperature": 0.0, "avg_logprob": -0.14380815650234705, "compression_ratio": 1.5733788395904438, "no_speech_prob": 1.8908685381346935e-12}, {"id": 343, "seek": 125806, "start": 1279.8999999999999, "end": 1283.8999999999999, "text": " QEC uses something called surface codes mapped onto a 2D grid.", "tokens": [51457, 1249, 8140, 4960, 746, 1219, 3753, 14211, 33318, 3911, 257, 568, 35, 10748, 13, 51657], "temperature": 0.0, "avg_logprob": -0.14380815650234705, "compression_ratio": 1.5733788395904438, "no_speech_prob": 1.8908685381346935e-12}, {"id": 344, "seek": 128390, "start": 1283.9, "end": 1292.6200000000001, "text": " Instead of storing one piece of logical information in one physical quibbit, the information is smeared across dozens of quibbits in a topological lattice.", "tokens": [50365, 7156, 295, 26085, 472, 2522, 295, 14978, 1589, 294, 472, 4001, 421, 897, 5260, 11, 264, 1589, 307, 41818, 1642, 2108, 18431, 295, 421, 897, 34010, 294, 257, 1192, 4383, 34011, 13, 50801], "temperature": 0.0, "avg_logprob": -0.1220244310033603, "compression_ratio": 1.750915750915751, "no_speech_prob": 1.6554991969300326e-12}, {"id": 345, "seek": 128390, "start": 1292.8200000000002, "end": 1293.74, "text": " So it's highly redundant.", "tokens": [50811, 407, 309, 311, 5405, 40997, 13, 50857], "temperature": 0.0, "avg_logprob": -0.1220244310033603, "compression_ratio": 1.750915750915751, "no_speech_prob": 1.6554991969300326e-12}, {"id": 346, "seek": 128390, "start": 1294.0, "end": 1297.8000000000002, "text": " It is redundant, but the brilliance is in how it checks for errors.", "tokens": [50870, 467, 307, 40997, 11, 457, 264, 8695, 6276, 307, 294, 577, 309, 13834, 337, 13603, 13, 51060], "temperature": 0.0, "avg_logprob": -0.1220244310033603, "compression_ratio": 1.750915750915751, "no_speech_prob": 1.6554991969300326e-12}, {"id": 347, "seek": 128390, "start": 1298.3600000000001, "end": 1302.3000000000002, "text": " The system uses Ancilla quibbits, helper quibbits, interspersed in the grid.", "tokens": [51088, 440, 1185, 4960, 1107, 66, 5291, 421, 897, 34010, 11, 36133, 421, 897, 34010, 11, 728, 4952, 433, 292, 294, 264, 10748, 13, 51285], "temperature": 0.0, "avg_logprob": -0.1220244310033603, "compression_ratio": 1.750915750915751, "no_speech_prob": 1.6554991969300326e-12}, {"id": 348, "seek": 128390, "start": 1302.7, "end": 1304.1000000000001, "text": " It doesn't measure the data itself.", "tokens": [51305, 467, 1177, 380, 3481, 264, 1412, 2564, 13, 51375], "temperature": 0.0, "avg_logprob": -0.1220244310033603, "compression_ratio": 1.750915750915751, "no_speech_prob": 1.6554991969300326e-12}, {"id": 349, "seek": 128390, "start": 1304.24, "end": 1306.5800000000002, "text": " It measures the parity between neighboring quibbits.", "tokens": [51382, 467, 8000, 264, 44747, 1296, 31521, 421, 897, 34010, 13, 51499], "temperature": 0.0, "avg_logprob": -0.1220244310033603, "compression_ratio": 1.750915750915751, "no_speech_prob": 1.6554991969300326e-12}, {"id": 350, "seek": 128390, "start": 1306.7800000000002, "end": 1308.8200000000002, "text": " It checks the geometry of the relationship.", "tokens": [51509, 467, 13834, 264, 18426, 295, 264, 2480, 13, 51611], "temperature": 0.0, "avg_logprob": -0.1220244310033603, "compression_ratio": 1.750915750915751, "no_speech_prob": 1.6554991969300326e-12}, {"id": 351, "seek": 128390, "start": 1308.92, "end": 1309.52, "text": " Oh, that's clever.", "tokens": [51616, 876, 11, 300, 311, 13494, 13, 51646], "temperature": 0.0, "avg_logprob": -0.1220244310033603, "compression_ratio": 1.750915750915751, "no_speech_prob": 1.6554991969300326e-12}, {"id": 352, "seek": 130952, "start": 1309.52, "end": 1322.12, "text": " If a cosmic ray flips a single physical quibbit, the surface code detects the anomaly, the syndrome, and corrects it in the background without ever collapsing the delicate quantum superposition of the actual data.", "tokens": [50365, 759, 257, 27614, 18592, 40249, 257, 2167, 4001, 421, 897, 5260, 11, 264, 3753, 3089, 5531, 82, 264, 42737, 11, 264, 19371, 11, 293, 3006, 82, 309, 294, 264, 3678, 1553, 1562, 45339, 264, 21417, 13018, 1687, 38078, 295, 264, 3539, 1412, 13, 50995], "temperature": 0.0, "avg_logprob": -0.08697959236476732, "compression_ratio": 1.6620689655172414, "no_speech_prob": 1.340477208400248e-12}, {"id": 353, "seek": 130952, "start": 1322.54, "end": 1325.06, "text": " Apply that back to the human AI governance model.", "tokens": [51016, 25264, 300, 646, 281, 264, 1952, 7318, 17449, 2316, 13, 51142], "temperature": 0.0, "avg_logprob": -0.08697959236476732, "compression_ratio": 1.6620689655172414, "no_speech_prob": 1.340477208400248e-12}, {"id": 354, "seek": 130952, "start": 1325.32, "end": 1325.98, "text": " How does that look?", "tokens": [51155, 1012, 775, 300, 574, 30, 51188], "temperature": 0.0, "avg_logprob": -0.08697959236476732, "compression_ratio": 1.6620689655172414, "no_speech_prob": 1.340477208400248e-12}, {"id": 355, "seek": 130952, "start": 1326.16, "end": 1337.48, "text": " If the trust between a human society and an AGI is modeled as entangled quantum spheres, a miscommunication, a dropped network packet, or an adversarial attack acts like a single quibit error.", "tokens": [51197, 759, 264, 3361, 1296, 257, 1952, 4086, 293, 364, 316, 26252, 307, 37140, 382, 948, 39101, 13018, 41225, 11, 257, 3346, 25451, 8758, 11, 257, 8119, 3209, 20300, 11, 420, 364, 17641, 44745, 2690, 10672, 411, 257, 2167, 421, 897, 270, 6713, 13, 51763], "temperature": 0.0, "avg_logprob": -0.08697959236476732, "compression_ratio": 1.6620689655172414, "no_speech_prob": 1.340477208400248e-12}, {"id": 356, "seek": 130952, "start": 1337.58, "end": 1337.86, "text": " Okay.", "tokens": [51768, 1033, 13, 51782], "temperature": 0.0, "avg_logprob": -0.08697959236476732, "compression_ratio": 1.6620689655172414, "no_speech_prob": 1.340477208400248e-12}, {"id": 357, "seek": 133786, "start": 1337.86, "end": 1347.54, "text": " The QEC functions as the societal laws and atmospheric resilience that instantly corrects those minor errors before they can cascade and corrupt the global trust metric.", "tokens": [50365, 440, 1249, 8140, 6828, 382, 264, 33472, 6064, 293, 28854, 19980, 300, 13518, 3006, 82, 729, 6696, 13603, 949, 436, 393, 50080, 293, 17366, 264, 4338, 3361, 20678, 13, 50849], "temperature": 0.0, "avg_logprob": -0.12386621747698102, "compression_ratio": 1.6827586206896552, "no_speech_prob": 1.7967511159455718e-12}, {"id": 358, "seek": 133786, "start": 1347.8, "end": 1348.54, "text": " That is mind-blowing.", "tokens": [50862, 663, 307, 1575, 12, 43788, 13, 50899], "temperature": 0.0, "avg_logprob": -0.12386621747698102, "compression_ratio": 1.6827586206896552, "no_speech_prob": 1.7967511159455718e-12}, {"id": 359, "seek": 133786, "start": 1349.1799999999998, "end": 1354.3, "text": " And the outline of the paper mentions a specific technique to manage this dynamically called lattice surgery.", "tokens": [50931, 400, 264, 16387, 295, 264, 3035, 23844, 257, 2685, 6532, 281, 3067, 341, 43492, 1219, 34011, 7930, 13, 51187], "temperature": 0.0, "avg_logprob": -0.12386621747698102, "compression_ratio": 1.6827586206896552, "no_speech_prob": 1.7967511159455718e-12}, {"id": 360, "seek": 133786, "start": 1354.6799999999998, "end": 1361.56, "text": " How does a quantum computer dynamically split or merge these topological grids while maintaining that logical coherence?", "tokens": [51206, 1012, 775, 257, 13018, 3820, 43492, 7472, 420, 22183, 613, 1192, 4383, 677, 3742, 1339, 14916, 300, 14978, 26528, 655, 30, 51550], "temperature": 0.0, "avg_logprob": -0.12386621747698102, "compression_ratio": 1.6827586206896552, "no_speech_prob": 1.7967511159455718e-12}, {"id": 361, "seek": 133786, "start": 1361.8799999999999, "end": 1365.4399999999998, "text": " Lattice surgery is the physical mechanism for dynamic governance.", "tokens": [51566, 441, 1591, 573, 7930, 307, 264, 4001, 7513, 337, 8546, 17449, 13, 51744], "temperature": 0.0, "avg_logprob": -0.12386621747698102, "compression_ratio": 1.6827586206896552, "no_speech_prob": 1.7967511159455718e-12}, {"id": 362, "seek": 136544, "start": 1365.44, "end": 1372.8, "text": " Imagine you have two separate topological patches on your quantum grid, each protected by its own surface code.", "tokens": [50365, 11739, 291, 362, 732, 4994, 1192, 4383, 26531, 322, 428, 13018, 10748, 11, 1184, 10594, 538, 1080, 1065, 3753, 3089, 13, 50733], "temperature": 0.0, "avg_logprob": -0.12574371538664164, "compression_ratio": 1.5720524017467248, "no_speech_prob": 1.6106144196115224e-12}, {"id": 363, "seek": 136544, "start": 1373.64, "end": 1384.38, "text": " Lattice surgery allows you to temporarily alter the boundary measurements between them, essentially unzipping the edges of the two codes and stitching them together into one larger unified surface code.", "tokens": [50775, 441, 1591, 573, 7930, 4045, 291, 281, 23750, 11337, 264, 12866, 15383, 1296, 552, 11, 4476, 517, 89, 6297, 264, 8819, 295, 264, 732, 14211, 293, 30714, 552, 1214, 666, 472, 4833, 26787, 3753, 3089, 13, 51312], "temperature": 0.0, "avg_logprob": -0.12574371538664164, "compression_ratio": 1.5720524017467248, "no_speech_prob": 1.6106144196115224e-12}, {"id": 364, "seek": 136544, "start": 1384.38, "end": 1387.52, "text": " And it does this completely fault-tolerantly.", "tokens": [51312, 400, 309, 775, 341, 2584, 7441, 12, 83, 27035, 3627, 13, 51469], "temperature": 0.0, "avg_logprob": -0.12574371538664164, "compression_ratio": 1.5720524017467248, "no_speech_prob": 1.6106144196115224e-12}, {"id": 365, "seek": 138752, "start": 1387.52, "end": 1393.02, "text": " It sounds exactly like performing a delicate skin graft on two adjoining soap bubbles.", "tokens": [50365, 467, 3263, 2293, 411, 10205, 257, 21417, 3178, 44767, 322, 732, 614, 5134, 1760, 14587, 16295, 13, 50640], "temperature": 0.0, "avg_logprob": -0.08917414058338512, "compression_ratio": 1.532967032967033, "no_speech_prob": 1.9736367488226714e-12}, {"id": 366, "seek": 138752, "start": 1393.74, "end": 1404.26, "text": " You carefully merge their surfaces to combine them into one massive bubble, but you execute the graft so perfectly that neither bubble pops and the internal pressure remains completely stable.", "tokens": [50676, 509, 7500, 22183, 641, 16130, 281, 10432, 552, 666, 472, 5994, 12212, 11, 457, 291, 14483, 264, 44767, 370, 6239, 300, 9662, 12212, 16795, 293, 264, 6920, 3321, 7023, 2584, 8351, 13, 51202], "temperature": 0.0, "avg_logprob": -0.08917414058338512, "compression_ratio": 1.532967032967033, "no_speech_prob": 1.9736367488226714e-12}, {"id": 367, "seek": 140426, "start": 1404.26, "end": 1411.4, "text": " Exactly. And if the alliance needs to end, you can perform the surgery in reverse, splitting the patch back into two isolated bubbles.", "tokens": [50365, 7587, 13, 400, 498, 264, 20995, 2203, 281, 917, 11, 291, 393, 2042, 264, 7930, 294, 9943, 11, 30348, 264, 9972, 646, 666, 732, 14621, 16295, 13, 50722], "temperature": 0.0, "avg_logprob": -0.07747731157528456, "compression_ratio": 1.810077519379845, "no_speech_prob": 1.728351728229327e-12}, {"id": 368, "seek": 140426, "start": 1412.08, "end": 1420.26, "text": " The authors suggest that we could eventually encode human-AI political treaties and alignment protocols directly into the topological surface of a quantum computer.", "tokens": [50756, 440, 16552, 3402, 300, 321, 727, 4728, 2058, 1429, 1952, 12, 48698, 3905, 48552, 293, 18515, 20618, 3838, 666, 264, 1192, 4383, 3753, 295, 257, 13018, 3820, 13, 51165], "temperature": 0.0, "avg_logprob": -0.07747731157528456, "compression_ratio": 1.810077519379845, "no_speech_prob": 1.728351728229327e-12}, {"id": 369, "seek": 140426, "start": 1420.62, "end": 1428.64, "text": " You're telling me this paper suggests we could encode human-AI political treaties into the topological surface of a quantum computer to mathematically guarantee trust?", "tokens": [51183, 509, 434, 3585, 385, 341, 3035, 13409, 321, 727, 2058, 1429, 1952, 12, 48698, 3905, 48552, 666, 264, 1192, 4383, 3753, 295, 257, 13018, 3820, 281, 44003, 10815, 3361, 30, 51584], "temperature": 0.0, "avg_logprob": -0.07747731157528456, "compression_ratio": 1.810077519379845, "no_speech_prob": 1.728351728229327e-12}, {"id": 370, "seek": 142864, "start": 1428.64, "end": 1443.14, "text": " Yes. By encoding the trust field into a surface code, with a sufficiently high distance, meaning enough physical quibits to absorb massive amounts of noise, we mathematically guarantee that the system can sustain mutual corrigibility.", "tokens": [50365, 1079, 13, 3146, 43430, 264, 3361, 2519, 666, 257, 3753, 3089, 11, 365, 257, 31868, 1090, 4560, 11, 3620, 1547, 4001, 421, 897, 1208, 281, 15631, 5994, 11663, 295, 5658, 11, 321, 44003, 10815, 300, 264, 1185, 393, 6769, 16917, 1181, 7065, 2841, 13, 51090], "temperature": 0.0, "avg_logprob": -0.09639773964881897, "compression_ratio": 1.556910569105691, "no_speech_prob": 1.8182073685188427e-12}, {"id": 371, "seek": 142864, "start": 1443.72, "end": 1452.0400000000002, "text": " The treaties aren't written on paper, subject to interpretation. They are encoded in the indestructible topological invariance of a quantum lattice.", "tokens": [51119, 440, 48552, 3212, 380, 3720, 322, 3035, 11, 3983, 281, 14174, 13, 814, 366, 2058, 12340, 294, 264, 1016, 43056, 964, 1192, 4383, 33270, 719, 295, 257, 13018, 34011, 13, 51535], "temperature": 0.0, "avg_logprob": -0.09639773964881897, "compression_ratio": 1.556910569105691, "no_speech_prob": 1.8182073685188427e-12}, {"id": 372, "seek": 145204, "start": 1452.04, "end": 1461.26, "text": " The scale of this vision is staggering. We've zoomed all the way out from Alonzo Church in the 1930s to thermodynamic ecosystems and quantum lattice treaties.", "tokens": [50365, 440, 4373, 295, 341, 5201, 307, 42974, 13, 492, 600, 8863, 292, 439, 264, 636, 484, 490, 967, 266, 4765, 7882, 294, 264, 22350, 82, 281, 8810, 34988, 32647, 293, 13018, 34011, 48552, 13, 50826], "temperature": 0.0, "avg_logprob": -0.08783820823386863, "compression_ratio": 1.5888157894736843, "no_speech_prob": 1.9508247014327074e-12}, {"id": 373, "seek": 145204, "start": 1461.48, "end": 1462.56, "text": " It's quite the journey.", "tokens": [50837, 467, 311, 1596, 264, 4671, 13, 50891], "temperature": 0.0, "avg_logprob": -0.08783820823386863, "compression_ratio": 1.5888157894736843, "no_speech_prob": 1.9508247014327074e-12}, {"id": 374, "seek": 145204, "start": 1463.26, "end": 1472.74, "text": " But the final paper brings us crashing back down to Earth to a startling, grounding realization about how all of this computation actually works at the absolute lowest level.", "tokens": [50926, 583, 264, 2572, 3035, 5607, 505, 26900, 646, 760, 281, 4755, 281, 257, 722, 1688, 11, 46727, 25138, 466, 577, 439, 295, 341, 24903, 767, 1985, 412, 264, 8236, 12437, 1496, 13, 51400], "temperature": 0.0, "avg_logprob": -0.08783820823386863, "compression_ratio": 1.5888157894736843, "no_speech_prob": 1.9508247014327074e-12}, {"id": 375, "seek": 145204, "start": 1472.8999999999999, "end": 1475.44, "text": " It strips away everything we think we know about logic.", "tokens": [51408, 467, 19842, 1314, 1203, 321, 519, 321, 458, 466, 9952, 13, 51535], "temperature": 0.0, "avg_logprob": -0.08783820823386863, "compression_ratio": 1.5888157894736843, "no_speech_prob": 1.9508247014327074e-12}, {"id": 376, "seek": 145204, "start": 1475.6, "end": 1479.26, "text": " It does. It introduces the concept of the universal operator machine.", "tokens": [51543, 467, 775, 13, 467, 31472, 264, 3410, 295, 264, 11455, 12973, 3479, 13, 51726], "temperature": 0.0, "avg_logprob": -0.08783820823386863, "compression_ratio": 1.5888157894736843, "no_speech_prob": 1.9508247014327074e-12}, {"id": 377, "seek": 147926, "start": 1479.26, "end": 1484.5, "text": " The core thesis is a direct quote from the source. Composition is more fundamental than typing.", "tokens": [50365, 440, 4965, 22288, 307, 257, 2047, 6513, 490, 264, 4009, 13, 6620, 5830, 307, 544, 8088, 813, 18444, 13, 50627], "temperature": 0.0, "avg_logprob": -0.11966753451623649, "compression_ratio": 1.6317689530685922, "no_speech_prob": 1.7553992114061057e-12}, {"id": 378, "seek": 147926, "start": 1485.04, "end": 1486.84, "text": " Which ties right back to the hook we started with today.", "tokens": [50654, 3013, 14039, 558, 646, 281, 264, 6328, 321, 1409, 365, 965, 13, 50744], "temperature": 0.0, "avg_logprob": -0.11966753451623649, "compression_ratio": 1.6317689530685922, "no_speech_prob": 1.7553992114061057e-12}, {"id": 379, "seek": 147926, "start": 1487.18, "end": 1498.8, "text": " It does. We humans are deeply attached to our syntax. We love our types, our proofs, our programming languages, and we especially love the concept of Boolean logic, the absolute certainty of true and false.", "tokens": [50761, 467, 775, 13, 492, 6255, 366, 8760, 8570, 281, 527, 28431, 13, 492, 959, 527, 3467, 11, 527, 8177, 82, 11, 527, 9410, 8650, 11, 293, 321, 2318, 959, 264, 3410, 295, 23351, 28499, 9952, 11, 264, 8236, 27022, 295, 2074, 293, 7908, 13, 51342], "temperature": 0.0, "avg_logprob": -0.11966753451623649, "compression_ratio": 1.6317689530685922, "no_speech_prob": 1.7553992114061057e-12}, {"id": 380, "seek": 147926, "start": 1499.72, "end": 1503.44, "text": " But the Flitchin papers argue that all of this is merely a human compression.", "tokens": [51388, 583, 264, 3235, 1549, 259, 10577, 9695, 300, 439, 295, 341, 307, 17003, 257, 1952, 19355, 13, 51574], "temperature": 0.0, "avg_logprob": -0.11966753451623649, "compression_ratio": 1.6317689530685922, "no_speech_prob": 1.7553992114061057e-12}, {"id": 381, "seek": 147926, "start": 1503.68, "end": 1504.22, "text": " A compression.", "tokens": [51586, 316, 19355, 13, 51613], "temperature": 0.0, "avg_logprob": -0.11966753451623649, "compression_ratio": 1.6317689530685922, "no_speech_prob": 1.7553992114061057e-12}, {"id": 382, "seek": 150422, "start": 1504.22, "end": 1511.94, "text": " Yes, it's a psychological illusion. It's a user interface skin designed to make the raw machinery of the universe legible to the human brain.", "tokens": [50365, 1079, 11, 309, 311, 257, 14346, 18854, 13, 467, 311, 257, 4195, 9226, 3178, 4761, 281, 652, 264, 8936, 27302, 295, 264, 6445, 1676, 964, 281, 264, 1952, 3567, 13, 50751], "temperature": 0.0, "avg_logprob": -0.13485921459433473, "compression_ratio": 1.528888888888889, "no_speech_prob": 1.617149122945527e-12}, {"id": 383, "seek": 150422, "start": 1512.4, "end": 1515.44, "text": " From the perspective of the machine, true and false do not exist.", "tokens": [50774, 3358, 264, 4585, 295, 264, 3479, 11, 2074, 293, 7908, 360, 406, 2514, 13, 50926], "temperature": 0.0, "avg_logprob": -0.13485921459433473, "compression_ratio": 1.528888888888889, "no_speech_prob": 1.617149122945527e-12}, {"id": 384, "seek": 150422, "start": 1516.16, "end": 1523.3600000000001, "text": " The execution engine of SpherePop doesn't care about Boolean logic. It doesn't care about fuzzy logic or neural networks or symbolic AI.", "tokens": [50962, 440, 15058, 2848, 295, 318, 6605, 38677, 1177, 380, 1127, 466, 23351, 28499, 9952, 13, 467, 1177, 380, 1127, 466, 34710, 9952, 420, 18161, 9590, 420, 25755, 7318, 13, 51322], "temperature": 0.0, "avg_logprob": -0.13485921459433473, "compression_ratio": 1.528888888888889, "no_speech_prob": 1.617149122945527e-12}, {"id": 385, "seek": 152336, "start": 1523.36, "end": 1530.02, "text": " At its absolute core, a program is just a directed, acyclic graph. A DAG.", "tokens": [50365, 1711, 1080, 8236, 4965, 11, 257, 1461, 307, 445, 257, 12898, 11, 696, 88, 66, 1050, 4295, 13, 316, 9578, 38, 13, 50698], "temperature": 0.0, "avg_logprob": -0.10479533806275786, "compression_ratio": 1.5021276595744681, "no_speech_prob": 1.8184261605172503e-12}, {"id": 386, "seek": 152336, "start": 1530.28, "end": 1535.3799999999999, "text": " A DAG is essentially a massive flowchart where data only moves in one direction, forward through the nodes.", "tokens": [50711, 316, 9578, 38, 307, 4476, 257, 5994, 3095, 339, 446, 689, 1412, 787, 6067, 294, 472, 3513, 11, 2128, 807, 264, 13891, 13, 50966], "temperature": 0.0, "avg_logprob": -0.10479533806275786, "compression_ratio": 1.5021276595744681, "no_speech_prob": 1.8184261605172503e-12}, {"id": 387, "seek": 152336, "start": 1535.4799999999998, "end": 1546.36, "text": " Exactly. A logic gate like an AND gate or an OR gate, which we treat as the fundamental building blocks of computing, is not some privileged, magical, metaphysical entity.", "tokens": [50971, 7587, 13, 316, 9952, 8539, 411, 364, 8093, 8539, 420, 364, 19654, 8539, 11, 597, 321, 2387, 382, 264, 8088, 2390, 8474, 295, 15866, 11, 307, 406, 512, 25293, 11, 12066, 11, 30946, 36280, 13977, 13, 51515], "temperature": 0.0, "avg_logprob": -0.10479533806275786, "compression_ratio": 1.5021276595744681, "no_speech_prob": 1.8184261605172503e-12}, {"id": 388, "seek": 154636, "start": 1546.36, "end": 1553.6599999999999, "text": " It's just an ordinary modular lookup function attached to a node in the graph. It takes an input, checks a table, and spits out an output.", "tokens": [50365, 467, 311, 445, 364, 10547, 31111, 574, 1010, 2445, 8570, 281, 257, 9984, 294, 264, 4295, 13, 467, 2516, 364, 4846, 11, 13834, 257, 3199, 11, 293, 637, 1208, 484, 364, 5598, 13, 50730], "temperature": 0.0, "avg_logprob": -0.09390572979025645, "compression_ratio": 1.497560975609756, "no_speech_prob": 1.5132594613151418e-12}, {"id": 389, "seek": 154636, "start": 1554.08, "end": 1562.9199999999998, "text": " What about control flow? When a programmer writes an if-then statement or a while loop, that feels like logic making a decision, like the computer is actually thinking.", "tokens": [50751, 708, 466, 1969, 3095, 30, 1133, 257, 32116, 13657, 364, 498, 12, 19096, 5629, 420, 257, 1339, 6367, 11, 300, 3417, 411, 9952, 1455, 257, 3537, 11, 411, 264, 3820, 307, 767, 1953, 13, 51193], "temperature": 0.0, "avg_logprob": -0.09390572979025645, "compression_ratio": 1.497560975609756, "no_speech_prob": 1.5132594613151418e-12}, {"id": 390, "seek": 156292, "start": 1562.92, "end": 1569.88, "text": " The paper demonstrates that control flow is an illusion. It is just the physical geometry of the DAG.", "tokens": [50365, 440, 3035, 31034, 300, 1969, 3095, 307, 364, 18854, 13, 467, 307, 445, 264, 4001, 18426, 295, 264, 9578, 38, 13, 50713], "temperature": 0.0, "avg_logprob": -0.08494982054067213, "compression_ratio": 1.6238938053097345, "no_speech_prob": 1.6555055937228502e-12}, {"id": 391, "seek": 156292, "start": 1570.3200000000002, "end": 1578.6200000000001, "text": " A branch in your code isn't a cognitive decision. It is just a node labeled SELECT that physically routes data down one wire instead of another.", "tokens": [50735, 316, 9819, 294, 428, 3089, 1943, 380, 257, 15605, 3537, 13, 467, 307, 445, 257, 9984, 21335, 10269, 2634, 10259, 300, 9762, 18242, 1412, 760, 472, 6234, 2602, 295, 1071, 13, 51150], "temperature": 0.0, "avg_logprob": -0.08494982054067213, "compression_ratio": 1.6238938053097345, "no_speech_prob": 1.6555055937228502e-12}, {"id": 392, "seek": 156292, "start": 1579.24, "end": 1586.5, "text": " A loop isn't a continuous thought. It is just feedback. A physical wire routing an output back to a previous input node.", "tokens": [51181, 316, 6367, 1943, 380, 257, 10957, 1194, 13, 467, 307, 445, 5824, 13, 316, 4001, 6234, 32722, 364, 5598, 646, 281, 257, 3894, 4846, 9984, 13, 51544], "temperature": 0.0, "avg_logprob": -0.08494982054067213, "compression_ratio": 1.6238938053097345, "no_speech_prob": 1.6555055937228502e-12}, {"id": 393, "seek": 158650, "start": 1586.5, "end": 1596.2, "text": " This is a massive paradigm shift. You're saying that syntax, programming languages like Python or C++A, and even the concept of true and false, are essentially just human illusions.", "tokens": [50365, 639, 307, 257, 5994, 24709, 5513, 13, 509, 434, 1566, 300, 28431, 11, 9410, 8650, 411, 15329, 420, 383, 25472, 32, 11, 293, 754, 264, 3410, 295, 2074, 293, 7908, 11, 366, 4476, 445, 1952, 49836, 13, 50850], "temperature": 0.0, "avg_logprob": -0.0966281569405888, "compression_ratio": 1.48828125, "no_speech_prob": 1.3046384719078707e-12}, {"id": 394, "seek": 158650, "start": 1596.62, "end": 1600.38, "text": " They are just UI skins over a universal composition graph.", "tokens": [50871, 814, 366, 445, 15682, 27888, 670, 257, 11455, 12686, 4295, 13, 51059], "temperature": 0.0, "avg_logprob": -0.0966281569405888, "compression_ratio": 1.48828125, "no_speech_prob": 1.3046384719078707e-12}, {"id": 395, "seek": 158650, "start": 1600.44, "end": 1602.98, "text": " Yes. A computer does not think in true or false.", "tokens": [51062, 1079, 13, 316, 3820, 775, 406, 519, 294, 2074, 420, 7908, 13, 51189], "temperature": 0.0, "avg_logprob": -0.0966281569405888, "compression_ratio": 1.48828125, "no_speech_prob": 1.3046384719078707e-12}, {"id": 396, "seek": 158650, "start": 1603.4, "end": 1608.34, "text": " SpherePop proves that Boolean logic is just one tiny, interchangeable library of operators.", "tokens": [51210, 318, 6605, 38677, 25019, 300, 23351, 28499, 9952, 307, 445, 472, 5870, 11, 30358, 712, 6405, 295, 19077, 13, 51457], "temperature": 0.0, "avg_logprob": -0.0966281569405888, "compression_ratio": 1.48828125, "no_speech_prob": 1.3046384719078707e-12}, {"id": 397, "seek": 160834, "start": 1608.34, "end": 1619.4199999999998, "text": " You could take the exact same geometric DAG, rip out the Boolean logic library, and plug in a fuzzy logic library, where truth isn't a binary one or zero, but a gradient, like 0.734.", "tokens": [50365, 509, 727, 747, 264, 1900, 912, 33246, 9578, 38, 11, 12782, 484, 264, 23351, 28499, 9952, 6405, 11, 293, 5452, 294, 257, 34710, 9952, 6405, 11, 689, 3494, 1943, 380, 257, 17434, 472, 420, 4018, 11, 457, 257, 16235, 11, 411, 1958, 13, 22, 12249, 13, 50919], "temperature": 0.0, "avg_logprob": -0.06657633414635292, "compression_ratio": 1.5709090909090908, "no_speech_prob": 1.6423643044508052e-12}, {"id": 398, "seek": 160834, "start": 1619.6999999999998, "end": 1621.4399999999998, "text": " And the execution engine wouldn't crash.", "tokens": [50933, 400, 264, 15058, 2848, 2759, 380, 8252, 13, 51020], "temperature": 0.0, "avg_logprob": -0.06657633414635292, "compression_ratio": 1.5709090909090908, "no_speech_prob": 1.6423643044508052e-12}, {"id": 399, "seek": 160834, "start": 1621.72, "end": 1628.34, "text": " It wouldn't even blink. It just keeps passing data through the nodes, applying whatever mathematical operation happens to be seated at that node.", "tokens": [51034, 467, 2759, 380, 754, 24667, 13, 467, 445, 5965, 8437, 1412, 807, 264, 13891, 11, 9275, 2035, 18894, 6916, 2314, 281, 312, 20959, 412, 300, 9984, 13, 51365], "temperature": 0.0, "avg_logprob": -0.06657633414635292, "compression_ratio": 1.5709090909090908, "no_speech_prob": 1.6423643044508052e-12}, {"id": 400, "seek": 160834, "start": 1628.86, "end": 1633.06, "text": " Truth values are just data. Logic is just an operator library.", "tokens": [51391, 20522, 4190, 366, 445, 1412, 13, 49898, 307, 445, 364, 12973, 6405, 13, 51601], "temperature": 0.0, "avg_logprob": -0.06657633414635292, "compression_ratio": 1.5709090909090908, "no_speech_prob": 1.6423643044508052e-12}, {"id": 401, "seek": 163306, "start": 1633.06, "end": 1644.12, "text": " The implications of that are massive. It means we don't need different architectures, different hardware, or different paradigms for symbolic AI, neural networks, or probability calculators.", "tokens": [50365, 440, 16602, 295, 300, 366, 5994, 13, 467, 1355, 321, 500, 380, 643, 819, 6331, 1303, 11, 819, 8837, 11, 420, 819, 13480, 328, 2592, 337, 25755, 7318, 11, 18161, 9590, 11, 420, 8482, 4322, 3391, 13, 50918], "temperature": 0.0, "avg_logprob": -0.08197433402739375, "compression_ratio": 1.5483870967741935, "no_speech_prob": 1.5251311498432063e-12}, {"id": 402, "seek": 163306, "start": 1644.44, "end": 1650.1399999999999, "text": " They're all exactly the same thing. Geometric graph composition. We've just been swapping out the math plugged into the nodes.", "tokens": [50934, 814, 434, 439, 2293, 264, 912, 551, 13, 2876, 29470, 4295, 12686, 13, 492, 600, 445, 668, 1693, 10534, 484, 264, 5221, 25679, 666, 264, 13891, 13, 51219], "temperature": 0.0, "avg_logprob": -0.08197433402739375, "compression_ratio": 1.5483870967741935, "no_speech_prob": 1.5251311498432063e-12}, {"id": 403, "seek": 163306, "start": 1650.34, "end": 1654.08, "text": " That is the ultimate revelation of the universal operator machine.", "tokens": [51229, 663, 307, 264, 9705, 23456, 295, 264, 11455, 12973, 3479, 13, 51416], "temperature": 0.0, "avg_logprob": -0.08197433402739375, "compression_ratio": 1.5483870967741935, "no_speech_prob": 1.5251311498432063e-12}, {"id": 404, "seek": 165408, "start": 1654.08, "end": 1659.62, "text": " It reveals that openness and composition are the true foundations of all complex systems.", "tokens": [50365, 467, 20893, 300, 36200, 293, 12686, 366, 264, 2074, 22467, 295, 439, 3997, 3652, 13, 50642], "temperature": 0.0, "avg_logprob": -0.12902921788832722, "compression_ratio": 1.5458715596330275, "no_speech_prob": 1.7216021360247358e-12}, {"id": 405, "seek": 165408, "start": 1660.26, "end": 1673.96, "text": " By forcing computation into rigid, isolated textual categories, by insisting on absolute true or false, or absolute safe or dangerous in our AI governance, we are actively fighting the natural geometry of information.", "tokens": [50674, 3146, 19030, 24903, 666, 22195, 11, 14621, 2487, 901, 10479, 11, 538, 13466, 278, 322, 8236, 2074, 420, 7908, 11, 420, 8236, 3273, 420, 5795, 294, 527, 7318, 17449, 11, 321, 366, 13022, 5237, 264, 3303, 18426, 295, 1589, 13, 51359], "temperature": 0.0, "avg_logprob": -0.12902921788832722, "compression_ratio": 1.5458715596330275, "no_speech_prob": 1.7216021360247358e-12}, {"id": 406, "seek": 165408, "start": 1674.36, "end": 1675.56, "text": " What an unbelievable journey.", "tokens": [51379, 708, 364, 16605, 4671, 13, 51439], "temperature": 0.0, "avg_logprob": -0.12902921788832722, "compression_ratio": 1.5458715596330275, "no_speech_prob": 1.7216021360247358e-12}, {"id": 407, "seek": 167556, "start": 1675.56, "end": 1685.06, "text": " I mean, we started with the limitations of typewriters in the 1930s, and learned how bursting geometric bubbles in a pre-sheave topos allows us to compute without syntax.", "tokens": [50365, 286, 914, 11, 321, 1409, 365, 264, 15705, 295, 2010, 86, 39335, 294, 264, 22350, 82, 11, 293, 3264, 577, 45713, 33246, 16295, 294, 257, 659, 12, 9611, 946, 1192, 329, 4045, 505, 281, 14722, 1553, 28431, 13, 50840], "temperature": 0.0, "avg_logprob": -0.16271875381469728, "compression_ratio": 1.6070175438596492, "no_speech_prob": 1.6045685830370915e-12}, {"id": 408, "seek": 167556, "start": 1685.6399999999999, "end": 1694.28, "text": " We explored how the jury monad and the independent channels lemma allow us to calculate the compounding thermodynamics of risk across parallel realities.", "tokens": [50869, 492, 24016, 577, 264, 19516, 1108, 345, 293, 264, 6695, 9235, 7495, 1696, 2089, 505, 281, 8873, 264, 14154, 278, 8810, 35483, 295, 3148, 2108, 8952, 27785, 13, 51301], "temperature": 0.0, "avg_logprob": -0.16271875381469728, "compression_ratio": 1.6070175438596492, "no_speech_prob": 1.6045685830370915e-12}, {"id": 409, "seek": 167556, "start": 1694.52, "end": 1694.6, "text": " Yeah.", "tokens": [51313, 865, 13, 51317], "temperature": 0.0, "avg_logprob": -0.16271875381469728, "compression_ratio": 1.6070175438596492, "no_speech_prob": 1.6045685830370915e-12}, {"id": 410, "seek": 167556, "start": 1694.96, "end": 1701.3799999999999, "text": " We redefined computer types not as static labels, but as mechanical locks and active refusal structures protecting our history.", "tokens": [51335, 492, 38818, 2001, 3820, 3467, 406, 382, 13437, 16949, 11, 457, 382, 12070, 20703, 293, 4967, 48948, 9227, 12316, 527, 2503, 13, 51656], "temperature": 0.0, "avg_logprob": -0.16271875381469728, "compression_ratio": 1.6070175438596492, "no_speech_prob": 1.6045685830370915e-12}, {"id": 411, "seek": 170138, "start": 1701.38, "end": 1714.2800000000002, "text": " We navigated the explosive AI safety crisis, discovering that extreme precaution mathematically guarantees systemic collapse, and that true alignment requires the messy entropic dialogue of mutual permeability.", "tokens": [50365, 492, 7407, 770, 264, 24630, 7318, 4514, 5869, 11, 24773, 300, 8084, 25651, 1448, 44003, 32567, 23789, 15584, 11, 293, 300, 2074, 18515, 7029, 264, 16191, 948, 39173, 10221, 295, 16917, 30287, 2310, 13, 51010], "temperature": 0.0, "avg_logprob": -0.08388987275742993, "compression_ratio": 1.6085526315789473, "no_speech_prob": 1.5675501261608327e-12}, {"id": 412, "seek": 170138, "start": 1714.44, "end": 1714.9, "text": " E